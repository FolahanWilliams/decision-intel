// ─── Structured RLHF (Moat 3) ────────────────────────────────────────────

model DecisionPrior {
  id                 String   @id @default(cuid())
  analysisId         String   @unique
  userId             String
  defaultAction      String   @db.Text // "What would you do with no info?"
  confidence         Float // 0-100
  evidenceToChange   String?  @db.Text // "What would change your mind?"
  postAnalysisAction String?  @db.Text // What they actually decided
  beliefDelta        Float? // Calculated shift
  createdAt          DateTime @default(now())

  analysis Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Outcomes-First Workflow (Moat 4) ─────────────────────────────────────

model DecisionFrame {
  id                String         @id @default(cuid())
  userId            String
  orgId             String?
  decisionStatement String         @db.Text
  defaultAction     String         @db.Text
  successCriteria   String[]
  failureCriteria   String[]
  stakeholders      String[]
  monetaryValue     Decimal? // Estimated decision value
  currency          String?        @default("GBP") // ISO currency code
  documentId        String?        @unique
  threadTs          String? // Slack thread timestamp for pre-decision monitoring
  channelId         String? // Slack channel ID for thread tracking
  linkedDecisionId  String?
  linkedDecision    HumanDecision? @relation("DecisionFrameLinkedDecision", fields: [linkedDecisionId], references: [id], onDelete: SetNull)
  nudgeCount        Int            @default(0) // How many nudges delivered in this thread
  escalationLevel   String         @default("none") // "none" | "info" | "warning" | "critical"
  accumulatedBiases Json? // Array of {bias, signal, detectedAt} across all thread messages
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  document Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)
  nudges   Nudge[]

  @@index([userId])
  @@index([orgId])
  @@index([channelId, threadTs])
  @@index([linkedDecisionId])
}

// ─── Deep Vertical Integration — Compliance (Moat 5) ─────────────────────

// ─── Decision Rooms (Real-Time Collaboration) ────────────────────────────

// ─── M7 — Dr. Red Team Persona ────────────────────────────────────────────
//
// Tracks user-invoked Red Team challenges on analyses or decision rooms.
// Persisted for four reasons:
//   (a) the UI needs to show prior challenges on revisit so users can
//       re-read the dissent they asked for,
//   (b) the per-challenge usefulness rating feeds the feedback loop so
//       we can calibrate which challenges users actually find valuable,
//   (c) the AuditLog entry gives us a provable record that a decision
//       was challenged before it was made (useful for compliance
//       "documented dissent" requirements),
//   (d) the playbook invocation pattern from M6 can eventually schedule
//       follow-up nudges against these challenges ("did you answer the
//       question Dr. Red Team asked you?").
model RedTeamChallenge {
  id                  String   @id @default(cuid())
  userId              String // who invoked Dr. Red Team
  orgId               String?
  analysisId          String? // scope: the analysis being challenged
  decisionRoomId      String? // scope: the decision room being challenged
  targetClaim         String   @db.Text // the single load-bearing assumption
  primaryObjection    String   @db.Text
  secondaryObjections String[] // flexible array — 0..N
  structuralQuestions String[]
  closingLine         String   @db.Text
  usefulRating        Int? // null | -1 (not useful) | 0 (neutral) | 1 (useful)
  notes               String?  @db.Text // free-text reaction
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([userId])
  @@index([orgId])
  @@index([analysisId])
  @@index([decisionRoomId])
  @@index([orgId, createdAt])
}

model DecisionRoom {
  id                      String                   @id @default(cuid())
  documentId              String?
  analysisId              String?
  title                   String
  createdBy               String // userId
  orgId                   String?
  status                  String                   @default("open") // open, closed, archived
  decisionType            String? // "investment_committee" | "board_review" | "deal_committee" | "risk_committee" | "general"
  consensusScore          Float? // 0-100, computed from blind prior convergence on close
  dissenterWeight         Json? // { userId: predictionAccuracy } — learned from outcomes
  outcomeId               String?
  outcome                 DecisionOutcome?         @relation(fields: [outcomeId], references: [id], onDelete: SetNull)
  biasBriefing            Json? // Auto-generated pre-meeting bias context from linked analysis
  closedAt                DateTime?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  /// Pre-IC blind-prior platform (4.1 deep). Survey closes at this timestamp.
  blindPriorDeadline      DateTime?
  /// Stamped when the owner-fired reveal flips the room from `collecting`
  /// to `revealed`. Once set, the per-participant aggregate is visible
  /// to every invitee. Nullable until the reveal fires.
  blindPriorRevealedAt    DateTime?
  /// Human-readable decision frame surfaced to invitees on the survey:
  /// e.g. "Should we approve Project Atlas at $40M?". Optional — when
  /// absent the room title is used.
  blindPriorOutcomeFrame  String?                  @db.Text
  participants            RoomParticipant[]
  blindPriors             BlindPrior[]
  decisionRoomBlindPriors DecisionRoomBlindPrior[]
  decisionRoomInvites     DecisionRoomInvite[]

  @@index([createdBy])
  @@index([orgId])
  @@index([status])
  @@index([decisionType])
  @@index([outcomeId])
  @@index([documentId])
  @@index([analysisId])
  @@index([blindPriorDeadline])
}

/// Pre-IC blind-prior submission. Decoupled from the legacy `BlindPrior`
/// model so the new procurement-grade fields (top risks, share-toggles,
/// per-participant Brier) don't have to backfill onto historical rows.
/// Either `respondentUserId` (existing platform user) or `respondentEmail`
/// (external invitee submitting via magic-link) is set — never both.
model DecisionRoomBlindPrior {
  id                String       @id @default(cuid())
  roomId            String
  /// Set when an existing platform user submits.
  respondentUserId  String?
  /// Set when an external invitee submits via the magic-link token flow.
  respondentEmail   String?
  /// Display name carried forward from the invite, used when
  /// `shareIdentity = true` so the reveal can attribute by name.
  respondentName    String?
  /// 0–100. Subjective probability the decision succeeds.
  confidencePercent Int
  /// Free-text top-3 risks. Each entry capped at 200 chars in the
  /// API; up to 3 entries.
  topRisks          String[]
  /// Optional one-sentence private rationale. Surfaced in the aggregate
  /// only when `shareRationale = true`.
  privateRationale  String?      @db.Text
  /// Whether the participant agreed to share their rationale in the reveal.
  shareRationale    Boolean      @default(false)
  /// Whether the participant agreed to share their identity (name) in
  /// the reveal. Defaults false — reveal is anonymised by default.
  shareIdentity     Boolean      @default(false)
  submittedAt       DateTime     @default(now())
  /// Brier score per participant computed once the linked outcome is
  /// logged. Lower is better calibrated. See src/lib/learning/brier-scoring.ts.
  brierScore        Float?
  brierCategory     String?
  brierCalculatedAt DateTime?
  room              DecisionRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, respondentUserId])
  @@unique([roomId, respondentEmail])
  @@index([roomId])
  @@index([respondentUserId])
  @@index([respondentEmail])
}

/// Per-invitee magic-link record for the blind-prior survey. Each row
/// owns a single-use signed token (consumed on submission). Existing
/// platform users get an invite AND a RoomParticipant row; external
/// invitees get only an invite. Both kinds resolve to a
/// DecisionRoomBlindPrior on submission.
model DecisionRoomInvite {
  id              String       @id @default(cuid())
  roomId          String
  /// Filled when invitee already has a platform account.
  userId          String?
  /// Filled when invitee is external (no platform account).
  email           String?
  /// Display name surfaced on the survey page + on the reveal aggregate
  /// when shareIdentity is true.
  displayName     String?
  role            String       @default("voter") // voter, observer
  /// Cryptographically random token. Single-use — `usedAt` is stamped
  /// on submission and the token is rotated to prevent replay.
  submissionToken String       @unique
  tokenExpiresAt  DateTime
  sentAt          DateTime     @default(now())
  /// Stamped when the invitee POSTs a valid blind-prior. Submission
  /// idempotent — if the same token is replayed, return the existing
  /// prior + 200, never duplicate.
  usedAt          DateTime?
  remindedAt      DateTime?
  room            DecisionRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@unique([roomId, email])
  @@index([roomId])
  @@index([submissionToken])
  @@index([tokenExpiresAt])
}

model RoomParticipant {
  id       String       @id @default(cuid())
  roomId   String
  userId   String
  role     String       @default("member") // creator, member, observer
  joinedAt DateTime     @default(now())
  room     DecisionRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([userId])
}

model BlindPrior {
  id            String       @id @default(cuid())
  roomId        String
  userId        String
  defaultAction String       @db.Text
  confidence    Float // 0-100
  reasoning     String?      @db.Text
  isRevealed    Boolean      @default(false) // blind until all submit
  submittedAt   DateTime     @default(now())
  room          DecisionRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([roomId])
}

