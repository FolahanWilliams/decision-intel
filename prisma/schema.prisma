  orgId                String?
  userId               String
  name                 String
  description          String    @db.Text
  category             String // m_and_a | board_review | risk_assessment | strategic_planning | investment_committee | custom
  industry             String? // Links to INDUSTRY_PROFILES key
  documentType         String? // Recommended document type
  complianceFrameworks String[] // e.g. ["fca_consumer_duty", "gdpr_art22"]
  biasFocus            String[] // Specific bias IDs to emphasize
