  @@index([userId])
  @@index([userId, weekStartDate])
}

/// Personal commitment statement. The "physical record" the founder comes
/// back to when feeling unmotivated. Multiple commitments allowed (one
/// at first sign-up; more added over time as discipline deepens). The UI
/// surfaces the most recent + lets the user re-read all prior ones.
model FounderOsCommitment {
  id        String   @id @default(cuid())
  userId    String
  text      String   @db.Text
  /// Optional title / context (e.g. "Day 1 commitment", "After Sankore call").
  title     String?  @db.VarChar(200)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, createdAt])
}

/// Faith OS prayer + reflection journal (2026-05-28). The spiritual sibling
/// of FounderOsCommitment — but where the commitment record is a fixed
/// anchor re-read when unmotivated, this is a running log. `kind` follows
/// the ACTS prayer framework (adoration / confession / thanksgiving /
/// supplication) plus a free `reflection` kind for journalled thoughts on a
/// passage. `answered` + `answeredNote` turn the supplication log into an
/// answered-prayer record over time — the faith equivalent of the
/// outcome-calibration loop: you see, in writing, what you asked for and
/// what came of it. Identity grounding, never a success-metric.
model FounderOsPrayerJournal {
  id          String    @id @default(cuid())
  userId      String
  /// adoration | confession | thanksgiving | supplication | reflection
  kind        String    @default("reflection")
  title       String?   @db.VarChar(300)
  body        String    @db.Text
  /// Optional scripture reference this entry is anchored to (e.g. "Proverbs 3:5-6").
  scriptureRef String?  @db.VarChar(120)
  /// Supplication entries can be marked answered later. Non-supplication
  /// entries leave this false; the UI only surfaces the toggle for prayers.
  answered    Boolean   @default(false)
  answeredNote String?  @db.Text
  answeredAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([userId, kind])
  @@index([userId, createdAt])
}

/// Faith OS reading-plan progress (2026-05-28). One row per (user, plan,
/// reference) read — idempotent via the unique index so re-marking a
/// passage read overwrites the reflection cleanly. `planId` keys into the
/// READING_PLANS SSOT ('proverbs' = a-chapter-a-day, 'founders-journey' =
/// the curated season-mapped plan). `reflection` is the optional
/// active-recall note (same encoding discipline as the content log).
model FounderOsReadingProgress {
  id         String   @id @default(cuid())
  userId     String
  planId     String
  /// Passage reference, e.g. "Proverbs 5" or "Joshua 1:9".
  reference  String   @db.VarChar(120)
  reflection String?  @db.Text
  completedAt DateTime @default(now())

  @@unique([userId, planId, reference])
  @@index([userId])
  @@index([userId, planId])
}

/// Faith OS "Today's Three" — daily-priority goal setting (2026-06-01).
/// The operating-system layer of Faith OS: the research-backed practice of
/// committing to AT MOST THREE clear priorities a day. The cap of three IS
/// the feature, not a limitation — it is the convergent finding across the
/// goal-setting science (working-memory limits ~4±1 + decision fatigue; the
/// Rule of 3; Buffett's 5/25 focus discipline; Keller's "The ONE Thing";
/// Make Time's single daily Highlight) AND the scriptural frame the rest of
/// Faith OS is built on (Prov 16:3 "commit your work to the LORD and your
/// plans will be established"; Matt 6:33 "seek first" → priority ordering;
/// Ps 90:12 "teach us to number our days"). One row per goal; the API
/// enforces ≤3 active goals per (userId, date) — the cap is server-enforced.
///   rank        1 = the day's highlight / ONE Thing, then 2, 3.
///   isHighlight the single most important of the three (Keller / Knapp).
///   intention   optional if-then implementation intention (Gollwitzer 1999)
///               — "if {trigger/when/where}, then I will {action}". The single
///               highest-leverage add-on; roughly doubles goal attainment.
///   status      open | done | carried | released. `released` is the
///               agency-surrender beat made concrete — a goal intentionally
///               let go, held with open hands (Prov 16:9 / James 4:13-15) —
///               NOT a failure. `carried` closes it honestly as "still
///               matters, not done today" — you re-set it tomorrow if it is
///               still one of the three. Both `carried` and `released` free
///               their slot against the day's cap of three.
///   committed   was the day's three rolled onto the Lord (Prov 16:3)? The
///               daily surrender act, recorded the way the prayer journal
///               records supplication — identity grounding, never a metric.
/// Deletes cascade via userId (string ref to Supabase auth, no FK), same as
/// every other FounderOs* model.
model FounderOsDailyGoal {
  id          String    @id @default(cuid())
  userId      String
  /// Local date string YYYY-MM-DD — the founder's day is HIS day, not UTC
  /// (matches FounderOsCheckin.date so the surfaces line up day-for-day).
  date        String
  text        String    @db.VarChar(280)
  rank        Int       @default(1)
  isHighlight Boolean   @default(false)
  intention   String?   @db.VarChar(400)
  /// Optional time-block for the goal (mainly the Highlight) — free text like
  /// "9:00-10:30" or "after standup" (Make Time pairs the Highlight with a
  /// when). Additive 2026-06-01.
  scheduledFor String?  @db.VarChar(120)
  /// Optional cascade link to the FounderOsPeriodGoal (weekly/quarterly) this
  /// daily goal serves — the Rule-of-3 hierarchy made real, so the day's work
  /// ladders up to the bigger rock instead of floating free. Soft ref (no FK)
  /// — same decoupled / schema-drift-tolerant discipline as the other soft
  /// links; a dangling id is treated as "no link". Additive 2026-06-01.
  linkedPeriodGoalId String?
  status      String    @default("open")
  committed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([userId, date])
}

/// Faith OS period goals — the weekly + quarterly cascade above Today's Three
/// (2026-06-01). The Rule of 3 is a hierarchy: a few quarter "rocks" → a few
/// weekly intentions → the day's three. Seeing the week's three above today's
/// three keeps the daily work laddering up to the bigger thing instead of
/// floating free (Locke clarity + Buffett focus; "where there is no vision the
/// people perish," Prov 29:18). The API enforces ≤3 active goals per
/// (userId, period, periodKey).
///   period     'week' | 'quarter'.
///   periodKey  ISO-week key 'YYYY-Www' (week) or 'YYYY-Qn' (quarter).
///   status     open | done | carried | released — same semantics as the daily
///              goal; carried + released free the slot against the cap.
model FounderOsPeriodGoal {
  id          String    @id @default(cuid())
  userId      String
  period      String
  periodKey   String
  text        String    @db.VarChar(280)
  rank        Int       @default(1)
  status      String    @default("open")
  committed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([userId, period, periodKey])
}

/// Faith OS evening reflection — the 60-second close on the day's three
/// (2026-06-01). Two honest lines: what MOVED (what actually advanced) and what
/// BLOCKED (the obstacle) — the Knapp "reflect" step + the scriptural discipline
/// of examining the day ("Let us test and examine our ways," Lam 3:40; Ps
/// 139:23-24). Feeds the weekly review + the pattern view; it is a record, never
/// a verdict on the day. One row per (userId, date), upserted.
model FounderOsDailyReflection {
  id        String   @id @default(cuid())
  userId    String
  date      String
  moved     String?  @db.Text
  blocked   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId])
  @@index([userId, date])
}

/// GTM v3.5 RATIFIED 2026-05-04 — micro-deliberation outcome event.
/// Fast-feedback signal that closes Cloverpop's data-advantage attack vector
/// without requiring 5-7-year macro-outcome wait times. Each Analysis can
/// produce many MicroDeliberationOutcome rows (one per predicted reaction
/// confirmed or refuted in the IC discussion / board review).
///
/// Why this exists: NotebookLM Q1 + Q3.1 (2026-05-04) converged on the
/// finding that v3.5's "Sankore engineers Brier loops in 12 weeks" assumption
/// is mathematically impossible for MACRO outcomes (deal IRR years out) but
/// trivially achievable for MICRO outcomes (committee reactions days out).
/// Brier scoring aggregates BOTH macro (DecisionOutcome) and micro
/// (MicroDeliberationOutcome) — the per-org calibration moat compounds
/// faster as a result.
model MicroDeliberationOutcome {
  id                  String    @id @default(cuid())
  analysisId          String
  userId              String
  orgId               String?
  /// One of: 'committee_pushback' | 'gc_flag' | 'chairman_concern' |
  /// 'reviewer_dismissal' | 'predicted_bias_surfaced' | 'cfo_objection' |
  /// 'compliance_block' | 'lp_question' | 'audit_committee_query' | 'other'.
  eventType           String
  /// The bias the audit predicted would surface in deliberation. Nullable
  /// for events that don't bind to a specific bias (e.g., 'lp_question').
  targetBiasId        String?
  /// What the audit predicted would happen in the deliberation, captured
  /// verbatim from the audit output at the time the user opened the
  /// micro-deliberation capture panel.
  predictedReaction   String    @db.Text
  /// What actually happened. Free text from the user.
  actualReaction      String?   @db.Text
  /// Did the predicted reaction match the actual reaction? null = not
  /// yet observed (the IC meeting hasn't happened, the board hasn't met).
  /// true = the audit predicted it AND it surfaced. false = the audit
  /// predicted it AND it did NOT surface (false-positive prediction).
  confirmed           Boolean?
  /// Confidence the audit assigned to this specific prediction at audit
  /// time (0-1). Used to compute per-prediction Brier increments when
  /// the user confirms/refutes.
  predictedConfidence Float?
  /// When the deliberation event actually occurred (the IC meeting / board
  /// review date). Null until the user logs the confirmation.
  happenedAt          DateTime?
  /// When the user captured this micro-deliberation event in the UI.
  capturedAt          DateTime  @default(now())
  /// Optional context — e.g. "GC raised the NDPR question 8 minutes into
  /// the discussion before I'd even brought it up."
  notes               String?   @db.Text

  analysis Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([analysisId])
  @@index([userId])
  @@index([orgId])
  @@index([userId, capturedAt])
  @@index([orgId, capturedAt])
  /// Dedicated index for per-org calibration aggregation queries — the
  /// Brier flywheel groups by orgId + confirmed and counts confirmations
  /// per bias type, so this composite is the hot path.
  @@index([orgId, eventType, confirmed])
}

model DecisionOutcome {
  id                  String   @id @default(cuid())
  analysisId          String   @unique
  userId              String
  orgId               String?
  outcome             String
  timeframe           String?
  impactScore         Int?
  notes               String?
  lessonsLearned      String?
  confirmedBiases     String[]
  falsePositiveBiases String[]
  mostAccurateTwin    String?
  /// Brier score between predicted DQI and actual outcome. Lower is
  /// better calibrated (0 = perfect, 1 = worst). Nullable for rows
  /// created before brier-scoring.ts shipped; populated on every
  /// outcome submission going forward. See src/lib/learning/brier-scoring.ts.
  brierScore          Float?
  /// Categorical calibration label derived from brierScore — 'excellent'
  /// (<= 0.10), 'good' (<= 0.20), 'fair' (<= 0.35), 'poor' (> 0.35).
  /// Stored alongside the raw score so filter / analytics queries don't
  /// have to recompute the bucket every read.
  brierCategory       String?
  reportedAt          DateTime @default(now())
  updatedAt           DateTime @updatedAt

  analysis      Analysis       @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  decisionRooms DecisionRoom[]

  @@index([analysisId])
  @@index([userId])
  @@index([orgId])
  @@index([outcome])
  @@index([reportedAt])
  @@index([userId, reportedAt])
  @@index([orgId, reportedAt])
  /// Dedicated index for per-org Brier trend queries — the outcome
  /// flywheel surface groups by reportedAt month and averages
  /// brierScore, so this composite index is the hot path.
  @@index([orgId, brierScore])
}

model BoardroomPersona {
  id            String   @id @default(cuid())
  orgId         String?
