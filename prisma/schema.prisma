generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector(schema: "extensions")]
}

model Document {
  id          String     @id @default(cuid())
  userId      String   // Supabase Auth User ID
  orgId       String?  // Organization ID
  filename    String
  fileType    String
  fileSize    Int
  content     String     @db.Text
  contentHash String?    @unique // For semantic caching - deduplication
  status      String     @default("pending")
  
  uploadedAt  DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  
  analyses    Analysis[]
  embeddings  DecisionEmbedding[]

  @@index([userId])
  @@index([updatedAt]) // For sorting by recent
  @@index([contentHash]) // For cache lookups
}

model Analysis {
  id           String         @id @default(cuid())
  documentId   String
  document     Document       @relation(fields: [documentId], references: [id], onDelete: Cascade)
  overallScore Float
  noiseScore   Float
  summary      String         @db.Text
  
  // New Agent Data Fields
  structuredContent String?      @db.Text
  speakers     String[]
  noiseStats   Json?          // Stores { mean, stdDev, variance }
  noiseBenchmarks Json?       // Stores [{ metric, documentValue, marketValue, variance, explanation }]
  factCheck    Json?          // Stores { score, flags }
  compliance   Json?          // Stores { status, details }
  preMortem    Json?          // Stores { failureScenarios, preventiveMeasures }
  sentiment    Json?          // Stores { score, label }
  logicalAnalysis Json?       // Stores { score, fallacies }
  swotAnalysis    Json?       // Stores { strengths, weaknesses, opportunities, threats, advice }
  cognitiveAnalysis Json?     // Stores { blindSpotGap, blindSpots, counterArguments }
  simulation      Json?       // Stores { overallVerdict, twins }
  institutionalMemory Json?   // Stores { recallScore, similarEvents, strategicAdvice }
  intelligenceContext Json?   // Stores { newsCount, researchCount, caseStudyCount, macroSummary, topNews, topCaseStudies }
  metaVerdict     String?     @db.Text
  
  // Visualizations
  biasWebImageUrl String?
  preMortemImageUrl String?

  preMortemRating Int?        // User rating of the failure scenarios
  modelVersion String?        // Gemini model used to produce this analysis

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  biases       BiasInstance[]

  @@index([documentId])
}

model BiasInstance {
  id          String   @id @default(cuid())
  analysisId  String
  analysis    Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  biasType    String
  severity    String
  excerpt     String   @db.Text
  explanation String   @db.Text
  suggestion  String   @db.Text
  confidence  Float?   @default(0.0)
  userRating  Int?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([analysisId])
}

model DecisionEmbedding {
  id String @id @default(cuid())
  documentId String
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  content String @db.Text
  embedding Unsupported("vector(1536)")?
  metadata Json?

  @@index([documentId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String   // Supabase Auth User ID
  orgId     String?  // Organization ID
  action    String   // e.g. "EXPORT_PDF", "SCAN_DOCUMENT"
  resource  String   // e.g. "Document", "Analysis"
  resourceId String?
  details   Json?
  ipAddress String?
  userAgent String?
  
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([orgId])
  @@index([action])
}



model UserSettings {
  id        String   @id @default(cuid())
  userId    String   @unique // One settings profile per user
  
  // Notification Preferences
  emailNotifications Boolean @default(true)
  analysisAlerts     Boolean @default(true)
  weeklyDigest       Boolean @default(false)
  
  // Display Preferences
  darkMode          Boolean @default(true)
  compactView       Boolean @default(false)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// Cache table - replaces Redis for cost savings
// TTL is enforced via expiresAt; expired rows are filtered on read and
// cleaned up lazily on write or via /api/cache/cleanup.
model CacheEntry {
  key       String   @id
  value     String   @db.Text
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

// ─── Web Intelligence Layer ───────────────────────────────────────────────

model NewsArticle {
  id             String   @id @default(cuid())
  title          String
  link           String   @unique
  source         String        // e.g. "HBR", "Reuters"
  feedCategory   String        // e.g. "psychology", "regulatory", "business"
  description    String   @db.Text
  publishedAt    DateTime
  expiresAt      DateTime      // 48h TTL — cleaned by cron
  extractedTopics String[]     // Gemini-classified topics
  biasTypes       String[]     // Applicable bias types (e.g. "anchoring", "groupthink")
  industrySector  String?      // e.g. "Technology", "Finance"
  relevanceScore  Float  @default(0) // 0-1 relevance to decision-making

  createdAt DateTime @default(now())

  @@index([feedCategory])
  @@index([expiresAt])
  @@index([publishedAt])
  @@index([relevanceScore])
}

model ResearchCache {
  id           String   @id @default(cuid())
  paperTitle   String
  authors      String[]
  year         Int?
  abstract     String   @db.Text
  doi          String?  @unique
  sourceUrl    String?
  biasTypes    String[]        // Which bias types this paper covers
  citationCount Int     @default(0)
  source       String          // "semantic_scholar" | "google_scholar"

  createdAt DateTime @default(now())
  expiresAt DateTime           // 30-day TTL

  @@index([biasTypes])
  @@index([expiresAt])
}

model CaseStudy {
  id          String   @id @default(cuid())
  company     String          // e.g. "Enron", "Nokia"
  title       String
  year        Int?
  summary     String   @db.Text
  biasTypes   String[]        // e.g. ["groupthink", "overconfidence"]
  outcome     String          // e.g. "bankruptcy", "market_loss"
  lessons     String   @db.Text
  industry    String?
  embedding   Unsupported("vector(1536)")?

  createdAt DateTime @default(now())

  @@index([biasTypes])
  @@index([industry])
}

model IntelligenceSync {
  id          String   @id @default(cuid())
  syncType    String          // "rss" | "research" | "full"
  status      String          // "success" | "partial" | "error"
  feedsProcessed Int  @default(0)
  articlesAdded  Int  @default(0)
  articlesExpired Int @default(0)
  errors      Json?           // Array of error descriptions
  durationMs  Int     @default(0)

  createdAt DateTime @default(now())

  @@index([syncType])
  @@index([createdAt])
}

// ─── Multi-Tenant Slack Integration ──────────────────────────────────────

model SlackInstallation {
  id             String   @id @default(cuid())
  teamId         String   @unique // Slack workspace ID (T-prefixed)
  teamName       String            // Human-readable workspace name
  orgId          String?           // Your internal organization ID (links to HumanDecision.orgId)
  installedByUserId String         // Supabase Auth User ID who authorized the app

  // OAuth credentials (encrypted at rest via application-layer AES-256-GCM)
  botTokenEncrypted  String  @db.Text  // Encrypted bot access token
  botTokenIv         String            // IV for AES-GCM decryption
  botTokenTag        String            // Auth tag for AES-GCM verification
  botUserId          String?           // Bot user ID in the workspace

  // Scopes granted during OAuth
  scopes             String[]          // e.g. ["channels:history", "chat:write", "channels:read"]

  // Status
  status             String  @default("active") // "active" | "revoked" | "expired"
  revokedAt          DateTime?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([teamId])
  @@index([orgId])
  @@index([installedByUserId])
  @@index([status])
}

// ─── Human Cognitive Auditing (Product B) ─────────────────────────────────

model HumanDecision {
  id           String   @id @default(cuid())
  userId       String   // Supabase Auth User ID (who submitted/ingested)
  orgId        String?  // Organization ID
  source       String   // "slack" | "meeting_transcript" | "email" | "jira" | "manual"
  sourceRef    String?  // External reference (Slack message ID, Jira ticket, etc.)
  channel      String?  // Source channel (e.g., #incident-response, board-meeting)
  decisionType String?  // "triage" | "escalation" | "approval" | "override" | "strategic" | "vendor_eval"
  participants String[] // Anonymized participant identifiers
  content      String   @db.Text // Anonymized decision text
  contentHash  String?  @unique  // For deduplication

  // Linked AI decision (bridges Product A ↔ Product B)
  linkedAnalysisId String?  // If this human decision relates to an AI-audited document

  status       String   @default("pending") // "pending" | "analyzed" | "error"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  cognitiveAudit CognitiveAudit?
  nudges         Nudge[]

  @@index([userId])
  @@index([orgId])
  @@index([source])
  @@index([channel])
  @@index([createdAt])
  @@index([contentHash])
}

model CognitiveAudit {
  id              String   @id @default(cuid())
  humanDecisionId String   @unique
  humanDecision   HumanDecision @relation(fields: [humanDecisionId], references: [id], onDelete: Cascade)

  // Scores
  decisionQualityScore Float   // 0-100 overall quality
  noiseScore           Float   // 0-100 consistency measure
  sentimentScore       Float?  // -1 to 1

  // Analysis outputs (JSON blobs)
  biasFindings     Json?  // Array of bias detections (same schema as BiasDetectionResult)
  noiseStats       Json?  // { mean, stdDev, variance }
  complianceResult Json?  // ComplianceResult
  preMortem        Json?  // { failureScenarios, preventiveMeasures }
  logicalAnalysis  Json?  // LogicalAnalysisResult
  sentimentDetail  Json?  // { score, label }

  // Team-level aggregation metadata
  teamConsensusFlag Boolean @default(false) // True if unanimous agreement detected
  dissenterCount    Int     @default(0)     // Number of dissenting voices

  // Visualizations
  biasWebImageUrl String?
  preMortemImageUrl String?

  summary         String  @db.Text
  modelVersion    String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([humanDecisionId])
  @@index([createdAt])
}

model Nudge {
  id              String   @id @default(cuid())
  humanDecisionId String?
  humanDecision   HumanDecision? @relation(fields: [humanDecisionId], references: [id], onDelete: SetNull)

  orgId           String?
  targetUserId    String?  // Anonymized recipient (null = team-level nudge)
  nudgeType       String   // "anchor_alert" | "dissent_prompt" | "base_rate_reminder" | "pre_mortem_trigger" | "noise_check"
  triggerReason   String   @db.Text // What triggered this nudge
  message         String   @db.Text // The nudge content shown to the user
  severity        String   @default("info") // "info" | "warning" | "critical"

  // Delivery
  channel         String   @default("dashboard") // "dashboard" | "slack" | "email"
  deliveredAt     DateTime?
  acknowledgedAt  DateTime?

  // Effectiveness tracking
  wasHelpful      Boolean? // User feedback on the nudge
  outcomeNotes    String?  @db.Text

  createdAt       DateTime @default(now())

  @@index([humanDecisionId])
  @@index([orgId])
  @@index([nudgeType])
  @@index([targetUserId])
  @@index([createdAt])
}

model TeamCognitiveProfile {
  id              String   @id @default(cuid())
  orgId           String
  periodStart     DateTime
  periodEnd       DateTime

  // Aggregated metrics (anonymous — no individual attribution)
  avgDecisionQuality Float
  avgNoiseScore      Float
  totalDecisions     Int    @default(0)
  topBiases          Json   // Array of { biasType, frequency, avgSeverity }
  consistencyTrend   Json?  // Array of { date, score } for sparkline
  nudgeEffectiveness Json?  // { sent, acknowledged, helpfulRate }

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([orgId, periodStart, periodEnd])
  @@index([orgId])
  @@index([periodStart])
}

// ─── Decision Outcomes Tracker (Feedback Loop) ──────────────────────────────

model DecisionOutcome {
  id           String   @id @default(cuid())
  analysisId   String   @unique  // Links to Analysis record
  userId       String             // Who reported the outcome
  orgId        String?

  // Outcome data
  outcome      String   // "success" | "partial_success" | "failure" | "too_early"
  timeframe    String?  // "30_days" | "60_days" | "90_days" | "6_months" | "1_year"
  impactScore  Int?     // 0-100 actual impact rating
  notes        String?  @db.Text  // Free-text explanation of what happened
  lessonsLearned String? @db.Text // Key takeaways

  // Which biases were actually problematic vs false positives
  confirmedBiases   String[] // Bias types that proved real
  falsPositiveBiases String[] // Bias types that were incorrect

  // Which Decision Twin was most accurate
  mostAccurateTwin  String?  // Name of the persona whose prediction was closest

  reportedAt  DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([analysisId])
  @@index([userId])
  @@index([orgId])
  @@index([outcome])
  @@index([reportedAt])
}

// ─── Custom Boardroom Personas ──────────────────────────────────────────────

model BoardroomPersona {
  id          String   @id @default(cuid())
  orgId       String?  // Null = system default; set = org-specific custom persona
  userId      String   // Creator

  name        String            // e.g. "Chief Medical Officer"
  role        String            // e.g. "CMO Proxy"
  focus       String   @db.Text // e.g. "Patient safety, clinical evidence, treatment outcomes"
  values      String   @db.Text // e.g. "Evidence-based medicine, do no harm, cost-effectiveness"
  bias        String   @db.Text // e.g. "Skeptical of treatments without randomized controlled trials"
  riskTolerance String @default("moderate") // "conservative" | "moderate" | "aggressive"

  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0) // Display order

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([orgId])
  @@index([userId])
  @@index([isActive])
}

// Rate limiting table - replaces Redis for cost savings
model RateLimit {
  id        String   @id @default(cuid())
  identifier String  // IP address or user ID
  route     String   // API route being limited
  count     Int      @default(0) // Number of requests made
  resetAt   DateTime // When the rate limit window resets
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([identifier, route])
  @@index([identifier])
  @@index([resetAt])
}
