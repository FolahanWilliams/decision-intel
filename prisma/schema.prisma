/// Per-container audit purchase — Stripe-backed pay-per-deal pricing
/// for high-value containers (typically acquisition + growth-stage
/// investment). Replaces legacy DealAuditPurchase.
model DecisionContainerAuditPurchase {
  id              String            @id @default(cuid())
  userId          String
  orgId           String?
  containerId     String
  stripePaymentId String            @unique
  tier            String // "small" | "mid" | "large" | "mega"
  amount          Int // cents
  currency        String            @default("USD")
  /// Container's ticket size at time of purchase (snapshot — the
  /// container itself can change ticketSize later without affecting
  /// already-billed audit access).
  ticketSize      Decimal
