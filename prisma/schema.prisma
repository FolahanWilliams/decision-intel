generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector(schema: "extensions")]
}

model Document {
  id          String     @id @default(cuid())
  userId      String   // Clerk User ID
  orgId       String?  // Clerk Organization ID
  filename    String
  fileType    String
  fileSize    Int
  content     String     @db.Text
  contentHash String?    @unique // For semantic caching - deduplication
  status      String     @default("pending")
  
  uploadedAt  DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  
  analyses    Analysis[]
  embeddings  DecisionEmbedding[]

  @@index([userId])
  @@index([updatedAt]) // For sorting by recent
  @@index([contentHash]) // For cache lookups
}

model Analysis {
  id           String         @id @default(cuid())
  documentId   String
  document     Document       @relation(fields: [documentId], references: [id], onDelete: Cascade)
  overallScore Float
  noiseScore   Float
  summary      String         @db.Text
  
  // New Agent Data Fields
  structuredContent String?      @db.Text
  speakers     String[]
  noiseStats   Json?          // Stores { mean, stdDev, variance }
  noiseBenchmarks Json?       // Stores [{ metric, documentValue, marketValue, variance, explanation }]
  factCheck    Json?          // Stores { score, flags }
  compliance   Json?          // Stores { status, details }
  preMortem    Json?          // Stores { failureScenarios, preventiveMeasures }
  sentiment    Json?          // Stores { score, label }
  logicalAnalysis Json?       // Stores { score, fallacies }
  swotAnalysis    Json?       // Stores { strengths, weaknesses, opportunities, threats, advice }
  cognitiveAnalysis Json?     // Stores { blindSpotGap, blindSpots, counterArguments }
  simulation      Json?       // Stores { overallVerdict, twins }
  institutionalMemory Json?   // Stores { recallScore, similarEvents, strategicAdvice }
  intelligenceContext Json?   // Stores { newsCount, researchCount, caseStudyCount, macroSummary, topNews, topCaseStudies }
  metaVerdict     String?     @db.Text

  preMortemRating Int?        // User rating of the failure scenarios
  modelVersion String?        // Gemini model used to produce this analysis

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  biases       BiasInstance[]

  @@index([documentId])
}

model BiasInstance {
  id          String   @id @default(cuid())
  analysisId  String
  analysis    Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  biasType    String
  severity    String
  excerpt     String   @db.Text
  explanation String   @db.Text
  suggestion  String   @db.Text
  confidence  Float?   @default(0.0)
  userRating  Int?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([analysisId])
}

model DecisionEmbedding {
  id String @id @default(cuid())
  documentId String
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  content String @db.Text
  embedding Unsupported("vector(1536)")?
  metadata Json?

  @@index([documentId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String   // Clerk User ID
  orgId     String?  // Clerk Organization ID
  action    String   // e.g. "EXPORT_PDF", "SCAN_DOCUMENT"
  resource  String   // e.g. "Document", "Analysis"
  resourceId String?
  details   Json?
  ipAddress String?
  userAgent String?
  
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([orgId])
  @@index([action])
}



model UserSettings {
  id        String   @id @default(cuid())
  userId    String   @unique // One settings profile per user
  
  // Notification Preferences
  emailNotifications Boolean @default(true)
  analysisAlerts     Boolean @default(true)
  weeklyDigest       Boolean @default(false)
  
  // Display Preferences
  darkMode          Boolean @default(true)
  compactView       Boolean @default(false)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// Cache table - replaces Redis for cost savings
// TTL is enforced via expiresAt; expired rows are filtered on read and
// cleaned up lazily on write or via /api/cache/cleanup.
model CacheEntry {
  key       String   @id
  value     String   @db.Text
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

// ─── Web Intelligence Layer ───────────────────────────────────────────────

model NewsArticle {
  id             String   @id @default(cuid())
  title          String
  link           String   @unique
  source         String        // e.g. "HBR", "Reuters"
  feedCategory   String        // e.g. "psychology", "regulatory", "business"
  description    String   @db.Text
  publishedAt    DateTime
  expiresAt      DateTime      // 48h TTL — cleaned by cron
  extractedTopics String[]     // Gemini-classified topics
  biasTypes       String[]     // Applicable bias types (e.g. "anchoring", "groupthink")
  industrySector  String?      // e.g. "Technology", "Finance"
  relevanceScore  Float  @default(0) // 0-1 relevance to decision-making

  createdAt DateTime @default(now())

  @@index([feedCategory])
  @@index([expiresAt])
  @@index([publishedAt])
  @@index([relevanceScore])
}

model ResearchCache {
  id           String   @id @default(cuid())
  paperTitle   String
  authors      String[]
  year         Int?
  abstract     String   @db.Text
  doi          String?  @unique
  sourceUrl    String?
  biasTypes    String[]        // Which bias types this paper covers
  citationCount Int     @default(0)
  source       String          // "semantic_scholar" | "google_scholar"

  createdAt DateTime @default(now())
  expiresAt DateTime           // 30-day TTL

  @@index([biasTypes])
  @@index([expiresAt])
}

model CaseStudy {
  id          String   @id @default(cuid())
  company     String          // e.g. "Enron", "Nokia"
  title       String
  year        Int?
  summary     String   @db.Text
  biasTypes   String[]        // e.g. ["groupthink", "overconfidence"]
  outcome     String          // e.g. "bankruptcy", "market_loss"
  lessons     String   @db.Text
  industry    String?
  embedding   Unsupported("vector(1536)")?

  createdAt DateTime @default(now())

  @@index([biasTypes])
  @@index([industry])
}

model IntelligenceSync {
  id          String   @id @default(cuid())
  syncType    String          // "rss" | "research" | "full"
  status      String          // "success" | "partial" | "error"
  feedsProcessed Int  @default(0)
  articlesAdded  Int  @default(0)
  articlesExpired Int @default(0)
  errors      Json?           // Array of error descriptions
  durationMs  Int     @default(0)

  createdAt DateTime @default(now())

  @@index([syncType])
  @@index([createdAt])
}

// Rate limiting table - replaces Redis for cost savings
model RateLimit {
  id        String   @id @default(cuid())
  identifier String  // IP address or user ID
  route     String   // API route being limited
  count     Int      @default(0) // Number of requests made
  resetAt   DateTime // When the rate limit window resets
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([identifier, route])
  @@index([identifier])
  @@index([resetAt])
}
