generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

// Zod schema generation (added 2026-05-01).
// Lean config — emits ONE model schema per Prisma model (Document, Analysis,
// etc.) into a single file. Skips Create/Update/Where input schemas (~100s
// of generated types we'd never use) so prisma generate stays fast.
//
// Use the generated `DocumentSchema` etc. as the canonical "shape of a
// Document" when serializing back to clients OR as a base for hand-written
// API request schemas: `DocumentSchema.pick({ filename: true, ... })`.
//
// Convention for new POST/PATCH routes: hand-write a Zod schema in
// src/lib/validation/<route-slug>.ts that derives from the generated model
// schema — keeps API input validation in lockstep with the Prisma schema.
generator zod {
  provider                         = "zod-prisma-types"
  output                           = "../src/generated/zod"
  useMultipleFiles                 = false
  createInputTypes                 = false
  createModelTypes                 = true
  addInputTypeValidation           = false
  createOptionalDefaultValuesTypes = false
  createRelationValuesTypes        = false
  writeBarrelFiles                 = false
  useDefaultValidators             = true
  coerceDate                       = false
  prismaClientPath                 = "@prisma/client"
}

datasource db {
  provider   = "postgresql"
  extensions = [pg_graphql(schema: "graphql"), pg_stat_statements(schema: "extensions"), pgcrypto(schema: "extensions"), uuid_ossp(map: "uuid-ossp", schema: "extensions"), vector(schema: "extensions")]
}

model Document {
  id                    String                      @id @default(cuid())
  userId                String
  filename              String
  fileType              String
  fileSize              Int
  content               String                      @db.Text
  contentEncrypted      String?                     @db.Text
  contentIv             String?
  contentTag            String?
  /// Key-rotation version stamp. Null = legacy (v1). Populated by new
  /// writes and by the rotate:encryption-key CLI. See
  /// src/lib/utils/encryption.ts for the protocol.
  contentKeyVersion     Int?
  uploadedAt            DateTime                    @default(now())
  status                String                      @default("pending")
  updatedAt             DateTime                    @updatedAt
  contentHash           String?                     @unique
  orgId                 String?
  documentType          String? // ic_memo | cim | pitch_deck | term_sheet | due_diligence | lp_report | qofe | synergy_model | integration_plan | other
  /// Type-aware structured parser output (locked 2026-05-09 — M&A cascade
  /// hard-layer ship). Populated at upload time when the parser detects a
  /// recognisable structure (today: synergy_model spreadsheets via
  /// extractSynergyStructure; future: qofe, integration_plan). The field
  /// holds a JSON-serialisable shape — currently SynergyStructure but the
  /// schema is intentionally generic so other parsers can use the same
  /// path without a migration. Null when the document type doesn't have a
  /// type-aware parser OR when extraction fell through to flat-text only.
  /// Replaces the inline-marker text round-trip in Document.content for
  /// downstream consumers (DPR, structured rendering, deal aggregation).
  parsedStructuredData  Json?
  source                String?
  sourceRef             String?
  isSample              Boolean                     @default(false) // Synthetic seed doc — clearable via /api/demo/clear-samples
  /// Soft-delete timestamp. Set when the user clicks Delete or when the
  /// retention cron passes the tier's window. Soft-deleted rows are
  /// invisible in normal queries; the enforce-retention cron hard-deletes
  /// them (DB cascade + storage cleanup) after a 30-day grace window.
  deletedAt             DateTime?
  /// Free-text reason populated when `deletedAt` is set. Values used today:
  /// 'user_request' | 'retention_expired' | 'org_offboard'.
  deletionReason        String?
  /// Document-level versioning. v1 of a memo has parentDocumentId=null. When
  /// the user uploads a revision via "Upload new version", we create a new
  /// Document row with parentDocumentId pointing to the ROOT of the chain
  /// (always v1's id, even for v3+). versionNumber counts from 1. To find
  /// all versions of a memo: WHERE id = X OR parentDocumentId = X.
  /// Plan reference: 2.3 — "DQI 42 → 71 (+29), sunk_cost_bias resolved,
  /// anchoring_bias emerged" delta loop.
  parentDocumentId      String?
  versionNumber         Int                         @default(1)
  /// Optional human-readable label for the version surface (e.g.
  /// "Pre-IC draft", "Post-counsel rev"). Free text, ≤80 chars enforced
  /// in the route. Falls back to "v{N}" in UI when null. (2.3 deep)
  versionLabel          String?
  /// Document-level access control (3.5). Values:
  ///   'private' — only `userId` can read/write (default for new uploads).
  ///   'team'    — anyone in the same org (matches the pre-3.5 default).
  ///   'specific' — explicit allowlist via DocumentAccess rows.
  /// The owner (matching `userId`) always retains full access regardless of
  /// this setting; visibility only controls what additional users can see.
  visibility            String                      @default("team")
  /// Stamp set by the retention cron when a pre-deletion warning email
  /// has been dispatched. Used to avoid duplicate warnings when the
  /// cron runs daily inside the warning window. Null = not yet warned.
  /// (2.1 deep)
  deletionWarningSentAt DateTime?
  /// Foreign key to a LegalHold row when this document is currently
  /// preserved from retention enforcement. The retention cron skips
  /// any document with a non-null legalHoldId. (2.1 deep)
  legalHoldId           String?
  legalHold             LegalHold?                  @relation(fields: [legalHoldId], references: [id], onDelete: SetNull)
  parentDocument        Document?                   @relation("DocumentVersions", fields: [parentDocumentId], references: [id], onDelete: SetNull)
  childVersions         Document[]                  @relation("DocumentVersions")
  analyses              Analysis[]
  embeddings            DecisionEmbedding[]
  failedAnalyses        FailedAnalysis[]
  decisionFrame         DecisionFrame?
  documentAccess        DocumentAccess[]
  containers            DecisionContainerDocument[]

  @@index([userId])
  @@index([orgId])
  @@index([updatedAt])
  @@index([contentHash])
  @@index([userId, uploadedAt])
  @@index([orgId, uploadedAt])
  @@index([source, sourceRef])
  @@index([orgId, isSample])
  @@index([deletedAt])
  @@index([parentDocumentId, versionNumber])
  @@index([deletionWarningSentAt])
  @@index([legalHoldId])
}

/// Legal-hold register (2.1 deep). When a document is on hold the
/// retention cron skips it entirely — soft-deletion stays manual, hard-
/// purge is blocked. Used for litigation, regulator inquiry, or
/// internal investigation. Owner-only setter today; admin-elevation
/// can be added as a follow-up without a schema change.
///
/// One LegalHold can attach to many documents (e.g. a single matter
/// covering a deal's full document set). The owner records `reason`
/// + `holdUntil` on creation; both are required for audit defensibility.
model LegalHold {
  id           String     @id @default(cuid())
  orgId        String?
  /// Human-readable reason — auditor needs to see why each hold exists.
  reason       String     @db.Text
  /// Optional sunset; null = until manually released.
  holdUntil    DateTime?
  grantedById  String
  releasedAt   DateTime?
  releasedById String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  documents    Document[]

  @@index([orgId])
  @@index([releasedAt])
}

/// Persisted Dalio structural-assumptions findings (1.3a deep).
/// Was previously a runtime-only on-demand audit; now persists per
/// analysis so the cross-analysis exposure aggregator can read them
/// without re-running the agent. One row per flagged determinant.
model StructuralAssumption {
  id                String   @id @default(cuid())
  analysisId        String
  /// Stable determinant id from src/lib/constants/dalio-determinants.ts
  /// (e.g. 'debt_cycle', 'currency_cycle', 'reserve_currency_status').
  determinantId     String
  determinantLabel  String?
  category          String? // 'cycles' | 'power' | 'fundamentals' | 'internal' | 'external'
  assumption        String   @db.Text
  defensibility     String // well_supported | partially_supported | unsupported | contradicted
  severity          String // low | medium | high | critical
  evidenceFromMemo  String?  @db.Text
  hardeningQuestion String?  @db.Text
  framework         String   @default("dalio-18-determinants")
  generatedAt       DateTime @default(now())
  /// Effective market context at the time of the run (so cross-analysis
  /// aggregation can filter by EM/DM exposure when surfacing patterns).
  marketContext     String? // emerging_market | developed_market | cross_border | unknown
  analysis          Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([analysisId])
  @@index([determinantId])
  @@index([severity])
  @@index([defensibility])
}

/// Cross-document conflict findings for a Deal (3.1 deep).
///
/// When a Deal has ≥2 analyzed documents, the cross-reference agent runs
/// over the latest analysis of each doc and surfaces contradictions:
/// numeric ("CIM says 40% CAGR, model assumes 15%"), assumption-level
/// ("memo says regulatory clear, counsel flags CBN ambiguity"), timeline,
/// risk-treatment, etc. The findings ARE the moat for the "deal as the
/// atomic decision unit" claim — looking at any single doc's DQI tells
/// you about the artifact, not the decision.
///
/// (Cross-reference run model lives below alongside DecisionContainer.)
///
/// Document-level access grants for the `visibility = 'specific'` mode (3.5).
/// One row per (document, user) grant. The Document.userId owner is implicit
/// — they always have full access; this table only holds *additional* grants.
model DocumentAccess {
  id          String   @id @default(cuid())
  documentId  String
  userId      String // grantee — references Supabase auth.users.id; not a relation since user IDs live across systems
  permission  String   @default("read") // 'read' | 'write' (write reserved for 2.x collab; v1 only enforces read)
  grantedById String // who issued the grant (typically the document owner)
  grantedAt   DateTime @default(now())
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, userId])
  @@index([userId])
  @@index([documentId])
}

/// DecisionContainer — the unified capital-allocation-decision
/// container (locked 2026-05-09 evening). Replaces the prior split
/// between `Deal` (M&A-coded) and `DecisionPackage` (generic-coded)
/// with one model + three workflow modes via the `kind` discriminator.
///
/// SSOT: src/lib/data/decision-container-modes.ts CONTAINER_MODES
///   - investment   → VC / growth / late-stage portfolio commitments
///   - acquisition  → corporate development / M&A buy-side
///   - strategic    → non-investment strategic decisions (market entry,
///                    product bet, restructure, etc.)
///
/// All three share the same R²F audit pipeline, DPR, composite DQI,
/// cross-doc conflict detection, and Brier-scored outcome calibration.
/// They diverge only on (a) stage labels via SSOT, (b) required docs at
/// the committee gate, (c) outcome metric shape, (d) committee label.
///
/// Documents attach via DecisionContainerDocument join table — same
/// document can appear in multiple containers (memo in Q4 board pack
/// AND DACH market entry). The join row carries per-context role label.
///
/// Visibility uses Document's three-state model — each member doc's
/// own visibility still applies; this only controls whether the
/// container SHELL shows up in another teammate's list view.
model DecisionContainer {
  id          String  @id @default(cuid())
  orgId       String?
  ownerUserId String

  /// SSOT-discriminator: 'investment' | 'acquisition' | 'strategic'.
  /// Drives mode-specific UI, outcome shape, required-doc rules. See
  /// CONTAINER_MODES in decision-container-modes.ts.
  kind String

  /// User-facing name. Investment: portco name. Acquisition: target
  /// name. Strategic: short label like "DACH market entry 2026".
  name String

  /// Free-text decision frame — the line the committee has to vote
  /// yes/no on. Especially central for strategic mode (where it IS
  /// the decision), encouraged for investment + acquisition.
  decisionFrame String? @db.Text

  /// Mode-specific stage id from SSOT (e.g. investment → 'sourcing',
  /// acquisition → 'diligence', strategic → 'drafting'). The kanban
  /// column. Validated against CONTAINER_MODES[kind].stages at write.
  stageId String

  /// Active/archived axis — independent of stage. 'archived' hides
  /// the container from default kanban view but preserves history.
  /// Lifecycle TERMINAL state (exited / outcome_logged) lives in
  /// stageId, not status.
  status String @default("active")

  /// Visibility — same three-state model as Document.
  visibility String @default("team")

  /// When the committee gate fired (decided / passed / approved).
  /// Set by the system when stageId moves past the committee_gate phase.
  decidedAt DateTime?

  /// Optional committee-gate target date. Drives "T-N days until
  /// {committeeLabel}" countdowns + sorts. Renames legacy Deal.icDate
  /// to reflect that acquisition mode uses "Board / IC Review" not
  /// just IC Review.
  committeeDate DateTime?

  // ─── Investment-mode optional fields ─────────────────────────────

  fundName String?
  vintage  Int?

  // ─── Acquisition-mode optional fields ────────────────────────────

  /// 'buyout' | 'growth_equity' | 'venture' | 'secondary' | 'add_on' |
  /// 'recapitalization'. Mostly informational — the kind discriminator
  /// already drives the UI behaviour.
  dealType String?

  // ─── Cross-mode optional fields ──────────────────────────────────

  /// Cheque size (investment) or purchase price (acquisition).
  /// Decimal for currency precision. Null for strategic mode.
  ticketSize Decimal?
  currency   String   @default("USD")

  /// Target company (acquisition: target being bought; investment:
  /// portco). Optional but populated for nearly all investment +
  /// acquisition rows.
  targetCompany String?

  /// Sector tag for analytics (technology / healthcare / industrials /
  /// consumer / financial_services / energy / etc.).
  sector String?

  /// Date when position was exited / decision concluded (post-outcome).
  exitDate DateTime?

  // ─── Composite metrics (cached on write) ─────────────────────────

  /// Composite DQI across the latest analysis of every member doc.
  /// Recomputed when docs are added/removed or new analyses land.
  compositeDqi              Float?
  compositeGrade            String? // A | B | C | D | F | null
  documentCount             Int     @default(0)
  analyzedDocCount          Int     @default(0)
  recurringBiasCount        Int     @default(0)
  conflictCount             Int     @default(0)
  highSeverityConflictCount Int     @default(0)

  /// Pre-artefact priors capture (locked 2026-05-10 per the Deep Research
  /// paper Ch 1 / Finding #1 — formalization-reality discontinuity). The
  /// actual cognitive commitment is forged BEFORE the IC memo lands; the
  /// memo is post-hoc rationalization. Capture conviction + kill criteria
  /// + 3 micro-predictions at DecisionFrame creation so the audit can
  /// compare against the user's pre-artefact reasoning, not just the
  /// engineered narrative.
  ///
  /// Shape (Json):
  /// {
  ///   convictionLevel: 'low' | 'medium' | 'high' | 'very_high',
  ///   convictionRationale: string,
  ///   killCriteria: string[],     // what would falsify this decision
  ///   microPredictions: Array<{   // Brier-scored proxies (paper Ch 9)
  ///     prediction: string,
  ///     horizonDays: number,      // 30 | 60 | 90 | 180
  ///     confidence: number,       // 0-1
  ///     resolvedAt?: string,
  ///     resolution?: 'true' | 'false' | 'partial',
  ///   }>,
  ///   capturedAt: string,
  ///   capturedByUserId: string,
  /// }
  priors Json?

  /// Cultural-pairing risk capture (locked 2026-05-10 per paper Ch 10 —
  /// Daimler-Chrysler / HP-Autonomy class failures). Required when a
  /// container's market context spans jurisdictions (acquirer ≠ target
  /// country, or emergingMarketCountries surfaced). Forces the team to
  /// explicitly name the regulatory pairing, the cultural integration
  /// risks, and a named historical analog deal — preventing the
  /// "cultural reasoning failure" that was the Daimler-Chrysler root
  /// cause according to the post-mortem literature.
  ///
  /// Shape (Json):
  /// {
  ///   regulatoryPairing: string,           // e.g. "EU AI Act + NDPR Nigeria"
  ///   culturalIntegrationRisks: string[],  // explicitly named risks
  ///   historicalAnalogDeal: string,        // canonical named comparable
  ///   gaapIfrsReconciliationNote?: string, // accounting-standard divergence
  ///   capturedAt: string,
  ///   capturedByUserId: string,
  /// }
  culturalPairingRisk Json?

  /// V2 — mandatory pre-mortem dissent gate (locked 2026-05-16).
  /// The sponsor's written defence to the Deal-Fever pre-mortem
  /// questions. Required (acquisition + analyzed docs) before an
  /// outcome can be logged; flows into the DPR as part of the
  /// human-oversight record. Shape: {
  ///   answers: Array<{
  ///     pattern: 'deal_fever' | 'winners_curse' | 'synergy_mirage',
  ///     question: string,        // verbatim from the premortem
  ///     writtenDefence: string,  // sponsor's answer (non-empty)
  ///   }>,
  ///   answeredByUserId: string,
  ///   answeredAt: string,        // ISO
  /// }
  /// @schema-drift-tolerant — null on pre-V2 rows + non-acquisition.
  premortemDefence Json?

  /// Adaptation #1 — Retroactive audit mode (locked 2026-05-21).
  /// When true, the container represents a HISTORICAL closed decision
  /// loaded with its outcome already known. Skips priors-capture
  /// (cannot fabricate pre-decision conviction retroactively — integrity
  /// boundary) and skips the 90-day forward proxy gate. Immediately
  /// triggers Bias Genome + Decision DNA + Knowledge Graph updates the
  /// moment the audit completes (because the outcome is already linked).
  ///
  /// The audit pipeline itself is identical to forward mode — same 12
  /// nodes, same kind-specific overlays (Synergy Mirage on
  /// acquisitions, etc.). Only the WORKFLOW changes.
  ///
  /// Compresses 12+ months of forward calibration into days of
  /// retroactive backfill — the Sankore-killer feature.
  /// @schema-drift-tolerant — defaults false; pre-2026-05-21 rows
  /// behave as forward containers.
  isRetroactive Boolean @default(false)

  /// Metadata for retroactive containers — when the original decision
  /// was made, when the outcome became known, the source of the
  /// historical record, and an optional bulk-upload batch grouping.
  /// Shape (Json):
  /// {
  ///   decidedAt: string,         // ISO — when the original decision was committed
  ///   outcomeKnownAt: string,    // ISO — when the outcome became known
  ///   sourceProvenance?: string, // e.g. "Sankore IC archive 2018"
  ///   bulkUploadBatchId?: string,// groups bulk-uploaded entries
  ///   pairingConfidence?: number,// 0-1, from the bulk-pairing engine
  ///   pairingMethod?: 'manual' | 'auto_high' | 'auto_medium' | 'auto_low',
  /// }
  /// @schema-drift-tolerant — null on non-retroactive containers.
  retroactiveMetadata Json?

  // ─── Timestamps ──────────────────────────────────────────────────

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ─── Relations ───────────────────────────────────────────────────

  documents       DecisionContainerDocument[]
  outcome         DecisionContainerOutcome?
  crossReferences DecisionContainerCrossReference[]
  auditPurchases  DecisionContainerAuditPurchase[]

  /// Phase 3.5 — Decision Pipeline Constellation. Outbound + inbound
  /// edges express cognitive lineage between containers (the thesis
  /// that spawned this deal, the prior decision it depends on, the
  /// parent strategic frame, etc.). See container-link-types SSOT.
  outboundLinks DecisionContainerLink[] @relation("LinkFromContainer")
  inboundLinks  DecisionContainerLink[] @relation("LinkToContainer")

  @@index([orgId])
  @@index([ownerUserId])
  @@index([orgId, kind])
  @@index([orgId, stageId])
  @@index([orgId, status])
  @@index([orgId, kind, status])
  @@index([orgId, updatedAt])
  @@index([committeeDate])
}

/// Phase 3.5 — Decision Pipeline Constellation edges (locked 2026-05-09
/// evening). Maps COGNITIVE LINEAGE between containers, not data
/// lineage (Palantir's trap). The four canonical link types per
/// container-link-types.ts SSOT:
///
/// - 'precedes'      — temporal: this decision came before that one;
///                     used for escalation-of-commitment chains.
/// - 'spawned_from'  — thesis-anchor: this deal flows from that thesis;
///                     master Strategic node → portfolio Investment nodes.
///                     The Cornerstone-magnetic edge per the master KB
///                     synthesis 2026-05-09.
/// - 'depends_on'    — structural: this decision rests on that
///                     assumption (Dalio determinant — debt cycle,
///                     governance, FX regime). Alert-ripple edge.
/// - 'parent_of'     — composition: this strategic frame contains
///                     that sub-decision (e.g. region rollout parent,
///                     market-by-market children).
///
/// `note` is optional free-text the creator adds when the link is
/// non-obvious (e.g. "depends on Q3 governance regime per Dangote DPR").
model DecisionContainerLink {
  id        String   @id @default(cuid())
  fromId    String
  toId      String
  /// One of: precedes | spawned_from | depends_on | parent_of.
  /// Validated against CONTAINER_LINK_TYPES SSOT at write.
  linkType  String
  note      String?  @db.Text
  createdAt DateTime @default(now())
  createdBy String?

  from DecisionContainer @relation("LinkFromContainer", fields: [fromId], references: [id], onDelete: Cascade)
  to   DecisionContainer @relation("LinkToContainer", fields: [toId], references: [id], onDelete: Cascade)

  @@unique([fromId, toId, linkType])
  @@index([fromId])
  @@index([toId])
  @@index([linkType])
}

/// Join table — Document ↔ DecisionContainer. Carries the per-context
/// role label ("memo" | "model" | "counsel review" | "deck" — free-form,
/// not enum'd because committee vocabulary varies) and the position so
/// the container detail page renders docs in a meaningful order.
model DecisionContainerDocument {
  id          String            @id @default(cuid())
  containerId String
  documentId  String
  /// Free-text role label per doc.
  role        String?
  /// Sort order in the container (0-indexed).
  position    Int               @default(0)
  addedAt     DateTime          @default(now())
  container   DecisionContainer @relation(fields: [containerId], references: [id], onDelete: Cascade)
  document    Document          @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([containerId, documentId])
  @@index([containerId, position])
  @@index([documentId])
}

/// Cross-reference run scoped to a container — replaces the prior
/// DealCrossReference + DecisionPackageCrossReference split. One row
/// per run; we keep history (runAt timestamps) so the UI can say
/// "as of {date}", which procurement appreciates.
model DecisionContainerCrossReference {
  id                String            @id @default(cuid())
  containerId       String
  runAt             DateTime          @default(now())
  /// Gemini model used for the run — pinned for reproducibility.
  modelVersion      String            @default("gemini-3-flash-preview")
  /// Snapshot of which (documentId → analysisId) pairs the run consumed,
  /// preserved across document versioning so older findings can still
  /// be cited.
  documentSnapshot  Json
  /// CrossRefRunOutput from src/lib/agents/cross-reference.ts —
  /// { summary, findings[], documentSnapshot[] }.
  findings          Json
  conflictCount     Int               @default(0)
  highSeverityCount Int               @default(0)
  status            String            @default("complete") // running | complete | error
  errorMessage      String?
  container         DecisionContainer @relation(fields: [containerId], references: [id], onDelete: Cascade)

  @@index([containerId, runAt])
}

/// Outcome reported on a DecisionContainer — replaces the prior
/// DealOutcome + DecisionPackageOutcome split. Mode-specific metric
/// fields live in the `metrics` JSON blob with shape matching the
/// SSOT outcomeShape.fields for the parent container's kind:
///
///   - investment   { irr, moic, exit_type, exit_value,
///                    hold_period_months, notes }
///   - acquisition  { synergy_realisation_pct, integration_milestones_hit_pct,
///                    talent_retention_pct, verdict, exit_value, notes }
///   - strategic    { forecast_hit, realised_value,
///                    time_to_outcome_months, lessons_learned }
///
/// Plain-English summary required. realisedDqi + brierScore optional
/// and computed on the back-end when the container's member analyses
/// recalibrate post-outcome (used by per-org Brier accumulation).
model DecisionContainerOutcome {
  id               String   @id @default(cuid())
  containerId      String   @unique
  summary          String   @db.Text
  /// Mode-specific metric blob — see SSOT outcomeShape.fields.
  metrics          Json
  /// DQI realisation after outcome — for Brier-scoring.
  realisedDqi      Float?
  brierScore       Float?
  reportedAt       DateTime @default(now())
  reportedByUserId String

  /// PMI signal capture for acquisition-mode containers (locked 2026-05-10
  /// per Tier 2 + PMI Path B). Treats PMI as the TARGET of the audit —
  /// did the deal deliver what the IC memo claimed? Not a new product
  /// domain, just the close-the-loop layer the existing audit was always
  /// missing.
  ///
  /// Shape (Json):
  /// {
  ///   signals: Array<{
  ///     key: 'synergy_realisation_pct' | 'talent_retention_pct' |
  ///          'integration_cost_vs_forecast' | 'day_one_milestone_hit_rate' |
  ///          'customer_retention_pct' | 'revenue_growth_vs_forecast',
  ///     proxy: string,            // verbatim IC-memo claim
  ///     horizonDays: number,      // 90 | 180 | 365
  ///     predictedConfidence: number, // 0-1 from priors / IC memo
  ///     observedValue?: number,
  ///     observedAt?: string,
  ///     brierScore?: number,
  ///     resolution?: 'hit' | 'miss' | 'partial' | 'unmeasured',
  ///   }>,
  ///   capturedAt: string,
  ///   capturedByUserId: string,
  ///   lastUpdatedAt?: string,
  /// }
  pmiSignals Json?

  container DecisionContainer @relation(fields: [containerId], references: [id], onDelete: Cascade)

  @@index([containerId])
}

model Analysis {
  id                    String   @id @default(cuid())
  documentId            String
  overallScore          Float
  noiseScore            Float
  summary               String   @db.Text
  createdAt             DateTime @default(now())
  compliance            Json?
  factCheck             Json?
  noiseStats            Json?
  preMortem             Json?
  sentiment             Json?
  speakers              String[]
  structuredContent     String?  @db.Text
  updatedAt             DateTime @updatedAt
  logicalAnalysis       Json?
  swotAnalysis          Json?
  cognitiveAnalysis     Json?
  simulation            Json?
  institutionalMemory   Json?
  modelVersion          String?
  noiseBenchmarks       Json?
  intelligenceContext   Json?
  metaVerdict           String?  @db.Text
  biasWebImageUrl       String?
  preMortemImageUrl     String?
  preMortemRating       Int?
  recognitionCues       Json?
  narrativePreMortem    Json?
  forgottenQuestions    Json?
  // Market-context priors applied by the bias detector (3.6). Shape:
  // { context, emergingMarketCountries[], developedMarketCountries[],
  //   cagrCeiling, rationale }. Null when the memo is jurisdiction-agnostic.
  marketContextApplied  Json?
  // Owner-supplied override of the auto-detection (3.6 deep). Same shape
  // plus an `overriddenAt` timestamp + the userId who flipped it. When
  // present, downstream surfaces (chip, structural-assumptions panel)
  // prefer this over `marketContextApplied`.
  marketContextOverride Json?

  // Version tracking and prompt reference
  version         Int            @default(1)
  promptVersionId String?
  promptVersion   PromptVersion? @relation(fields: [promptVersionId], references: [id], onDelete: SetNull)

  // Cross-document version delta link. Set automatically when an analysis
  // is created on a Document with a parentDocumentId — points to the most
  // recent Analysis on the immediate predecessor in the version chain. The
  // VersionDeltaCard on the document detail page renders DQI delta + bias
  // resolved/emerged when this is populated. Plan reference: 2.3.
  previousAnalysisId String?
  previousAnalysis   Analysis?  @relation("AnalysisVersionDelta", fields: [previousAnalysisId], references: [id], onDelete: SetNull)
  derivedAnalyses    Analysis[] @relation("AnalysisVersionDelta")

  // Outcome tracking — mandatory flywheel
  outcomeStatus   String    @default("pending_outcome") // pending_outcome | outcome_logged | outcome_overdue
  outcomeDueAt    DateTime? // When outcome should be reported
  recalibratedDqi Json? // { originalScore, recalibratedScore, recalibratedGrade, delta, recalibratedAt }
  /// Granular per-judge outputs captured during the pipeline run so the
  /// Decision Provenance Record can show actual judge variance (1.1
  /// deep). Shape: { biasDetective: { ... }, noiseJudge: { ... },
  /// statisticalJury: { ... }, metaJudge: { ... } }. Null on legacy
  /// analyses. Surfacing this on the DPR closes a procurement gap —
  /// previously we cited variance at a coarse level only.
  judgeOutputs    Json?

  // Synthetic seed analysis — flagged SAMPLE, clearable via /api/demo/clear-samples
  isSample Boolean @default(false)

  document              Document               @relation(fields: [documentId], references: [id], onDelete: Cascade)
  biases                BiasInstance[]
  versions              AnalysisVersion[]
  shareLinks            ShareLink[]
  outcome               DecisionOutcome?
  prior                 DecisionPrior?
  /// Persisted Dalio structural-assumptions findings (1.3a deep).
  structuralAssumptions StructuralAssumption[]

  toxicCombinations         ToxicCombination[]
  draftOutcomes             DraftOutcome[]
  fingerprintWarnings       FingerprintWarning[]
  provenanceRecord          DecisionProvenanceRecord?
  /// GTM v3.5 — fast-feedback micro-deliberation events captured during
  /// or after the IC / board review meeting where this analysis was
  /// presented. Each row is one predicted-reaction confirmation/refutation.
  microDeliberationOutcomes MicroDeliberationOutcome[]

  @@index([documentId])
  @@index([createdAt])
  @@index([documentId, createdAt])
  @@index([isSample])
  @@index([outcomeStatus, outcomeDueAt]) // Outcome gate reminders query
}

/// Short-lived monthly-analysis quota reservation. A row is inserted (under a
/// per-user advisory lock) the instant a plan-limited audit is admitted, and
/// deleted when the pipeline finishes. This closes the cost race where two
/// concurrent requests both pass a bare count-then-create limit check and both
/// run the ~£0.40 pipeline: the second request's atomic count now sees the
/// first's reservation. Orphans from a crash mid-pipeline are swept by TTL on
/// the next reserve. See reserveAnalysisSlot / releaseAnalysisSlot in
/// src/lib/utils/plan-limits.ts. Additive table — pre-migration deployments
/// fall back to the legacy non-atomic check (fail-open on schema drift).
model AnalysisReservation {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

