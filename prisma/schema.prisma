  createdAt       DateTime          @default(now())
  container       DecisionContainer @relation(fields: [containerId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([containerId])
  @@index([orgId])
}

/// Constellation Next Move — intelligent-antagonist priority capture
/// (locked 2026-05-10 per Deep Research paper Ch 8 / Finding #4 —
/// automation-bias defense). Before the system reveals its ranked
/// recommendations on the constellation, the user names what THEY
/// think the highest-priority decision is. The named gap between
/// user-priority and algo-priority is the recommendation's actual
/// value — not the recommendation alone. The capture is logged
/// per-render so we can quarterly review the user's calibration.
model ConstellationPriorityCapture {
  id                      String   @id @default(cuid())
  userId                  String
  orgId                   String?
  capturedAt              DateTime @default(now())
  /// 1-2 sentence freeform — the user's named highest-priority
  /// container, in their own language, before seeing the algo output.
  userPriorityText        String   @db.Text
  /// Optional containerId the user named (parsed from the text via
  /// LLM intent-extraction). Null when the user-priority doesn't map
  /// cleanly to a single container.
  userPriorityContainerId String?
  /// The algorithm's top-ranked containerId at the moment of capture.
  algoTopContainerId      String?
  /// The "why this fires" trace string for the algo's top pick,
  /// snapshotted so the divergence record stays interpretable even
  /// after the underlying signals shift.
  algoTopReason           String?  @db.Text
  /// 0.0 = perfect agreement; 1.0 = total mismatch. Computed from
  /// (a) container-id match, (b) ranked-list overlap. Used for
  /// quarterly calibration review.
  divergenceScore         Float?

  @@index([userId])
  @@index([orgId])
  @@index([userId, capturedAt])
}

/// Anti-Portfolio tracking — locked 2026-05-10 per Deep Research paper
/// Ch 4 (Bessemer Anti-Portfolio model). Track decisions the user
/// PASSED ON via explicit reject + outcome attribution. Surfaces
/// false-negative patterns (decisions we should have made but didn't)
/// the same way the audit pipeline surfaces false-positive patterns
/// (decisions we made but shouldn't have).
///
/// Bessemer's discipline: institutionalize vulnerability by publicly
/// documenting failures of imagination. The Anti-Portfolio neutralizes
/// the ego-defense mechanisms that block organizational learning from
/// passes.
model RejectedDecision {
  id                          String    @id @default(cuid())
  userId                      String
  orgId                       String?
  /// User-facing name (target company, fund opportunity, strategic
  /// option). Mirrors DecisionContainer.name shape.
  name                        String
  /// What was the decision. Same free-text shape as
  /// DecisionContainer.decisionFrame.
  decisionFrame               String?   @db.Text
  /// 'investment' | 'acquisition' | 'strategic' — same kind enum as
  /// DecisionContainer so the Anti-Portfolio can be filtered + sorted
  /// alongside active containers.
  kind                        String
  /// Sector / industry tag, mirrors DecisionContainer.sector.
  sector                      String?
  /// Date the IC / committee / user formally passed.
  rejectedAt                  DateTime  @default(now())
  /// Rationale at time of rejection. Critical for the post-hoc
  /// learning loop — when the eventual outcome lands, we compare
  /// the rejection reason to the actual driver.
  rejectionReason             String    @db.Text
  /// Did a competitor / different fund / different acquirer pick this
  /// up? Surfaces "this happened in the market" attribution.
  passedToCompetitor          Boolean   @default(false)
  competitorName              String?
  /// Eventual outcome attribution. Populated when the user logs
  /// observed outcome 6+ months post-rejection. Shape:
  /// {
  ///   outcomeBand: 'outlier_success' | 'modest_success' | 'wash' |
  ///                'modest_failure' | 'outlier_failure',
  ///   evidence: string,           // headline / news / disclosure
  ///   evidenceUrl?: string,
  ///   learnedLesson: string,      // free-text retrospective
  ///   wouldRedecideToday: 'yes' | 'no' | 'still_unclear',
  ///   loggedAt: string,
  /// }
  eventualOutcome             Json?
  eventualOutcomeAttributedAt DateTime?
  /// Soft-delete to match DecisionContainer pattern; the daily
  /// /api/cron/enforce-retention pass hard-purges after the grace
  /// window.
  deletedAt                   DateTime?
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt

  @@index([userId])
  @@index([orgId])
  @@index([userId, rejectedAt])
  @@index([kind])
  @@index([sector])
}

model GoogleDriveInstallation {
  id                    String    @id @default(cuid())
