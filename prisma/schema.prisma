  whyItMatters   String?  @db.Text
  preAssessment  String?  @db.Text
  postAssessment String?  @db.Text
  status         String   @default("planned")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@index([userId, status])
}

/// Sunday weekly review — three questions, twenty minutes. Top-3 long-form
/// pieces with active-recall summaries, one skill note, internal-locus
/// reflection. Unique per user per weekStartDate.
model FounderOsWeeklyReview {
