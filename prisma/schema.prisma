model CaseStudy {
  id                   String                 @id @default(cuid())
  title                String
  industry             String?
  outcome              String
  createdAt            DateTime               @default(now())
  biasTypes            String[]
  company              String
  embedding            Unsupported("vector")?
  lessons              String
  summary              String
  year                 Int?
  impactDirection      String?
  impactScore          Int?
  estimatedImpact      String?
  biasesManaged        String[]
  mitigationFactors    String[]
  beneficialPatterns   String[]
  survivorshipBiasRisk String?
  source               String?
  sourceType           String?
  decisionContext      String?

  @@index([biasTypes])
  @@index([industry])
  @@index([outcome])
}

model IntelligenceSync {
  id              String   @id @default(cuid())
  status          String
  articlesAdded   Int      @default(0)
  articlesExpired Int      @default(0)
  createdAt       DateTime @default(now())
  durationMs      Int      @default(0)
  errors          Json?
  feedsProcessed  Int      @default(0)
  syncType        String

  @@index([syncType])
  @@index([createdAt])
}

model Organization {
  id                 String             @id @default(cuid())
  name               String
  slug               String             @unique
  avatarUrl          String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  isAnonymized       Boolean            @default(false) // Consent to anonymous aggregation
  /// Per-org retention override (2.1 deep). When set, the retention
  /// cron uses this value instead of the plan-tier default for documents
  /// owned by this org. Min 30 days enforced in the API. Null = use the
  /// plan-tier default from src/lib/utils/plan-limits.ts.
  retentionDaysOverride Int?
  invites            TeamInvite[]
  members            TeamMember[]
  ssoConfigurations  SsoConfiguration[]

  @@index([slug])
}

// SAML / OIDC SSO configuration per Org.
//
// Supabase's SAML model is project-level, not tenant-level. Each customer's
// IdP is registered once with Supabase (via `supabase sso add` or the Admin
// API) and returns a stable provider UUID that we persist in `providerId`.
// `domain` is the email domain we match at login — when `alice@acme.com`
// signs in, we look up `domain='acme.com'`, find the active provider, and
// call supabase.auth.signInWithSSO({ domain }).
//
// One Org can register multiple domains (e.g. acme.com + acme.co.uk) by
// creating multiple rows; each row maps a single domain to a single provider.
model SsoConfiguration {
  id                 String       @id @default(cuid())
  orgId              String
  /** Email domain matched at login. Lowercased, no leading @, no trailing dot. */
  domain             String
  /** Stable Supabase `sso_provider_id` UUID returned by `supabase sso add`. */
  providerId         String
  /** 'saml' | 'oidc' — matches Supabase's provider type. Saml is the only
   *  form supported at launch. */
  protocol           String       @default("saml")
  /** Human-facing label used in admin UI (e.g. "Okta · Acme Inc"). */
  displayName        String?
  /** 'pending' (created, not yet registered with Supabase) |
   *  'active' (registered + verified) |
   *  'disabled' (manually suspended, login falls back to password). */
  status             String       @default("pending")
  /** Timestamp the first successful SAML login landed. */
  activatedAt        DateTime?
  /** Free-text notes — the admin's contact at the IdP, ticket reference, etc. */
  notes              String?      @db.Text
  createdAt          DateTime     @default(now())
  createdByUserId    String?
  updatedAt          DateTime     @updatedAt
  organization       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([domain])
  @@index([orgId])
  @@index([providerId])
}

model TeamMember {
  id               String       @id @default(cuid())
  orgId            String
  userId           String
  email            String
  displayName      String?
  role             String       @default("member")
  joinedAt         DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  // Knowledge Graph merge consent. Set when an individual Pro user's
  // org upgrades to Strategy/Enterprise and they have personal memos
  // that could merge into the team graph.
  // Values: null (not applicable), "pending", "merged", "private".
  kgMergeConsent   String?
  kgMergeDecidedAt DateTime?
  organization     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@unique([orgId, email])
  @@index([orgId])
  @@index([userId])
}

model TeamInvite {
  id              String       @id @default(cuid())
  orgId           String
  email           String
  role            String       @default("member")
  invitedByUserId String
  token           String       @unique @default(cuid())
  status          String       @default("pending")
  createdAt       DateTime     @default(now())
  expiresAt       DateTime
  organization    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, email])
  @@index([orgId])
  @@index([email])
  @@index([token])
}

model SlackInstallation {
  id                String    @id @default(cuid())
  teamId            String    @unique
  teamName          String
  orgId             String?
  installedByUserId String
  botTokenEncrypted String
  botTokenIv        String
  botTokenTag       String
  /// Key-rotation version stamp. Null = legacy (v1). See
  /// src/lib/utils/encryption.ts for the protocol.
  botTokenKeyVersion Int?
  botUserId         String?
  scopes            String[]
  monitoredChannels String[]  @default([])
  nudgeFrequency    String    @default("normal")
  status            String    @default("active")
  revokedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([teamId])
  @@index([orgId])
  @@index([installedByUserId])
  @@index([status])
}

model Meeting {
  id                    String             @id @default(cuid())
  userId                String
  orgId                 String?
  title                 String
  meetingType           String             @default("general")
  source                String             @default("upload")
  sourceRef             String?
  fileName              String?
  fileType              String?
  fileSize              Int?
  storagePath           String?
  durationSeconds       Int?
  participants          String[]
  status                String             @default("uploading")
  errorMessage          String?
  transcriptionProgress Float              @default(0)
  summary               String?
  actionItems           Json?
  keyDecisions          Json?
  speakerBiases         Json?
  similarMeetings       Json?
  humanDecisionId       String?            @unique
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  humanDecision         HumanDecision?     @relation(fields: [humanDecisionId], references: [id], onDelete: SetNull)
  transcript            MeetingTranscript?

  @@index([userId])
  @@index([orgId])
  @@index([status])
  @@index([createdAt])
  @@index([userId, status])
}

model MeetingTranscript {
  id         String   @id @default(cuid())
  meetingId  String   @unique
  speakers   Json     @default("[]")
  segments   Json     @default("[]")
  fullText   String
  language   String   @default("en")
  confidence Float    @default(0)
  createdAt  DateTime @default(now())
  meeting    Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
}

model HumanDecision {
  id               String          @id @default(cuid())
  userId           String
  orgId            String?
  source           String
  sourceRef        String?
  channel          String?
  decisionType     String?
  participants     String[]
  content          String
  contentHash      String?         @unique
  linkedAnalysisId String?
  status           String          @default("pending")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
