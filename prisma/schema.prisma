generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pg_graphql(schema: "graphql"), pg_stat_statements(schema: "extensions"), pgcrypto(schema: "extensions"), uuid_ossp(map: "uuid-ossp", schema: "extensions"), vector(schema: "extensions")]
}

model Document {
  id          String              @id @default(cuid())
  userId      String
  filename    String
  fileType    String
  fileSize    Int
  content     String              @db.Text
  uploadedAt  DateTime            @default(now())
  status      String              @default("pending")
  updatedAt   DateTime            @updatedAt
  contentHash String?             @unique
  orgId       String?
  analyses    Analysis[]
  embeddings  DecisionEmbedding[]
  failedAnalyses FailedAnalysis[]

  @@index([userId])
  @@index([orgId])
  @@index([updatedAt])
  @@index([contentHash])
}

model Analysis {
  id                  String         @id @default(cuid())
  documentId          String
  overallScore        Float
  noiseScore          Float
  summary             String        @db.Text
  createdAt           DateTime       @default(now())
  compliance          Json?
  factCheck           Json?
  noiseStats          Json?
  preMortem           Json?
  sentiment           Json?
  speakers            String[]
  structuredContent   String?        @db.Text
  updatedAt           DateTime       @updatedAt
  logicalAnalysis     Json?
  swotAnalysis        Json?
  cognitiveAnalysis   Json?
  simulation          Json?
  institutionalMemory Json?
  modelVersion        String?
  noiseBenchmarks     Json?
  intelligenceContext Json?
  metaVerdict         String?        @db.Text
  biasWebImageUrl     String?
  preMortemImageUrl   String?
  preMortemRating     Int?

  // Version tracking and prompt reference
  version         Int             @default(1)
  promptVersionId String?         // FK to PromptVersion used for this analysis

  document            Document       @relation(fields: [documentId], references: [id], onDelete: Cascade)
  biases              BiasInstance[]
  versions     AnalysisVersion[]
  shareLinks   ShareLink[]
  outcome      DecisionOutcome?

  @@index([documentId])
}

model BiasInstance {
  id          String   @id @default(cuid())
  analysisId  String
  biasType    String
  severity    String
  excerpt     String   @db.Text
  explanation String   @db.Text
  suggestion  String   @db.Text
  confidence  Float?   @default(0.0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userRating  Int?
  analysis    Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([analysisId])
}

model DecisionEmbedding {
  id         String                 @id @default(cuid())
  documentId String
  content    String
  embedding  Unsupported("vector")?
  metadata   Json?
  document   Document               @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  orgId      String?
  action     String
  resource   String
  resourceId String?
  details    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([orgId])
  @@index([action])
}

model UserSettings {
  id                 String   @id @default(cuid())
  userId             String   @unique
  updatedAt          DateTime @updatedAt
  analysisAlerts     Boolean  @default(true)
  createdAt          DateTime @default(now())
  darkMode           Boolean  @default(true)
  emailNotifications Boolean  @default(true)
  weeklyDigest       Boolean  @default(false)

  @@index([userId])
}

model CacheEntry {
  key       String   @id
  value     String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

model NewsArticle {
  id              String   @id @default(cuid())
  title           String
  source          String
  publishedAt     DateTime
  relevanceScore  Float    @default(0)
  biasTypes       String[]
  createdAt       DateTime @default(now())
  description     String
  expiresAt       DateTime
  extractedTopics String[]
  feedCategory    String
  industrySector  String?
  link            String   @unique

  @@index([feedCategory])
  @@index([expiresAt])
  @@index([publishedAt])
  @@index([relevanceScore])
}

model ResearchCache {
  id            String   @id @default(cuid())
  doi           String?  @unique
  abstract      String
  authors       String[]
  biasTypes     String[]
  createdAt     DateTime @default(now())
  expiresAt     DateTime
  citationCount Int      @default(0)
  paperTitle    String
  source        String
  sourceUrl     String?
  year          Int?

  @@index([biasTypes])
  @@index([expiresAt])
}

model CaseStudy {
  id        String                 @id @default(cuid())
  title     String
  industry  String?
  outcome   String
  createdAt DateTime               @default(now())
  biasTypes String[]
  company   String
  embedding Unsupported("vector")?
  lessons   String
  summary   String
  year      Int?

  @@index([biasTypes])
  @@index([industry])
}

model IntelligenceSync {
  id              String   @id @default(cuid())
  status          String
  articlesAdded   Int      @default(0)
  articlesExpired Int      @default(0)
  createdAt       DateTime @default(now())
  durationMs      Int      @default(0)
  errors          Json?
  feedsProcessed  Int      @default(0)
  syncType        String

  @@index([syncType])
  @@index([createdAt])
}

model Organization {
  id        String       @id @default(cuid())
  name      String
  slug      String       @unique
  avatarUrl String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  invites   TeamInvite[]
  members   TeamMember[]

  @@index([slug])
}

model TeamMember {
  id           String       @id @default(cuid())
  orgId        String
  userId       String
  email        String
  displayName  String?
  role         String       @default("member")
  joinedAt     DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@index([orgId])
  @@index([userId])
}

model TeamInvite {
  id              String       @id @default(cuid())
  orgId           String
  email           String
  role            String       @default("member")
  invitedByUserId String
  token           String       @unique @default(cuid())
  status          String       @default("pending")
  createdAt       DateTime     @default(now())
  expiresAt       DateTime
  organization    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([email])
  @@index([token])
}

model SlackInstallation {
  id                String    @id @default(cuid())
  teamId            String    @unique
  teamName          String
  orgId             String?
  installedByUserId String
  botTokenEncrypted String
  botTokenIv        String
  botTokenTag       String
  botUserId         String?
  scopes            String[]
  status            String    @default("active")
  revokedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([teamId])
  @@index([orgId])
  @@index([installedByUserId])
  @@index([status])
}

model Meeting {
  id                    String             @id @default(cuid())
  userId                String
  orgId                 String?
  title                 String
  meetingType           String             @default("general")
  source                String             @default("upload")
  sourceRef             String?
  fileName              String?
  fileType              String?
  fileSize              Int?
  storagePath           String?
  durationSeconds       Int?
  participants          String[]
  status                String             @default("uploading")
  errorMessage          String?
  transcriptionProgress Float              @default(0)
  summary               String?
  actionItems           Json?
  keyDecisions          Json?
  speakerBiases         Json?
  similarMeetings       Json?
  humanDecisionId       String?            @unique
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  humanDecision         HumanDecision?     @relation(fields: [humanDecisionId], references: [id])
  transcript            MeetingTranscript?

  @@index([userId])
  @@index([orgId])
  @@index([status])
  @@index([createdAt])
}

model MeetingTranscript {
  id         String   @id @default(cuid())
  meetingId  String   @unique
  speakers   Json     @default("[]")
  segments   Json     @default("[]")
  fullText   String
  language   String   @default("en")
  confidence Float    @default(0)
  createdAt  DateTime @default(now())
  meeting    Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
}

model HumanDecision {
  id               String          @id @default(cuid())
  userId           String
  orgId            String?
  source           String
  sourceRef        String?
  channel          String?
  decisionType     String?
  participants     String[]
  content          String
  contentHash      String?         @unique
  linkedAnalysisId String?
  status           String          @default("pending")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  cognitiveAudit   CognitiveAudit?
  meeting          Meeting?
  nudges           Nudge[]

  @@index([userId])
  @@index([orgId])
  @@index([source])
  @@index([channel])
  @@index([createdAt])
  @@index([contentHash])
}

model CognitiveAudit {
  id                   String        @id @default(cuid())
  humanDecisionId      String        @unique
  decisionQualityScore Float
  noiseScore           Float
  sentimentScore       Float?
  biasFindings         Json?
  noiseStats           Json?
  complianceResult     Json?
  preMortem            Json?
  logicalAnalysis      Json?
  swotAnalysis         Json?
  sentimentDetail      Json?
  teamConsensusFlag    Boolean       @default(false)
  dissenterCount       Int           @default(0)
  biasWebImageUrl      String?
  preMortemImageUrl    String?
  summary              String
  modelVersion         String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  humanDecision        HumanDecision @relation(fields: [humanDecisionId], references: [id], onDelete: Cascade)

  @@index([humanDecisionId])
  @@index([createdAt])
}

model Nudge {
  id              String         @id @default(cuid())
  targetUserId    String?
  orgId           String?
  humanDecisionId String?
  nudgeType       String
  message         String
  createdAt       DateTime       @default(now())
  acknowledgedAt  DateTime?
  channel         String         @default("dashboard")
  deliveredAt     DateTime?
  outcomeNotes    String?
  severity        String         @default("info")
  triggerReason   String
  wasHelpful      Boolean?
  humanDecision   HumanDecision? @relation(fields: [humanDecisionId], references: [id])

  @@index([humanDecisionId])
  @@index([orgId])
  @@index([nudgeType])
  @@index([targetUserId])
  @@index([createdAt])
}

model TeamCognitiveProfile {
  id                 String   @id @default(cuid())
  orgId              String
  periodStart        DateTime
  periodEnd          DateTime
  createdAt          DateTime @default(now())
  avgDecisionQuality Float
  avgNoiseScore      Float
  consistencyTrend   Json?
  nudgeEffectiveness Json?
  totalDecisions     Int      @default(0)
  updatedAt          DateTime @updatedAt
  topBiases          Json

  @@unique([orgId, periodStart, periodEnd])
  @@index([orgId])
  @@index([periodStart])
}

model DecisionOutcome {
  id                 String   @id @default(cuid())
  analysisId         String   @unique
  userId             String
  orgId              String?
  outcome            String
  timeframe          String?
  impactScore        Int?
  notes              String?
  lessonsLearned     String?
  confirmedBiases    String[]
  falsPositiveBiases String[]
  mostAccurateTwin   String?
  reportedAt         DateTime @default(now())
  updatedAt          DateTime @updatedAt

  analysis Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([analysisId])
  @@index([userId])
  @@index([orgId])
  @@index([outcome])
  @@index([reportedAt])
}

model BoardroomPersona {
  id            String   @id @default(cuid())
  orgId         String?
  userId        String
  name          String
  role          String
  focus         String
  values        String
  bias          String
  riskTolerance String   @default("moderate")
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([orgId])
  @@index([userId])
  @@index([isActive])
}

model ShareLink {
  id           String    @id @default(cuid())
  token        String    @unique @default(cuid())
  analysisId   String
  userId       String
  orgId        String?
  expiresAt    DateTime
  revokedAt    DateTime?
  password     String?
  viewCount    Int       @default(0)
  lastViewedAt DateTime?
  createdAt    DateTime  @default(now())

  analysis   Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  accesses   ShareLinkAccess[]

  @@index([token])
  @@index([analysisId])
  @@index([userId])
  @@index([expiresAt])
}

model NotificationLog {
  id        String   @id @default(cuid())
  userId    String
  channel   String
  type      String
  subject   String?
  status    String   @default("sent")
  metadata  Json?
  error     String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([channel])
  @@index([type])
  @@index([createdAt])
}

model RateLimit {
  id         String   @id @default(cuid())
  identifier String
  route      String
  count      Int      @default(0)
  resetAt    DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, route])
  @@index([identifier])
  @@index([resetAt])
}

// ─── Versioning & Observability Models ─────────────────────────────────────

model AnalysisVersion {
  id            String   @id @default(cuid())
  analysisId    String
  analysis      Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  version       Int      @default(1)
  overallScore  Float
  noiseScore    Float
  summary       String   @db.Text
  biases        Json     // snapshot of BiasInstance[] at this version
  fullSnapshot  Json     // complete analysis output snapshot
  createdAt     DateTime @default(now())

  @@unique([analysisId, version])
  @@index([analysisId])
}

model PromptVersion {
  id          String   @id @default(cuid())
  name        String   // e.g. "BIAS_DETECTIVE_PROMPT", "SIMULATION_SUPER_PROMPT"
  version     Int
  hash        String   // SHA-256 of prompt content for change detection
  content     String   @db.Text
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@unique([name, version])
  @@index([name, isActive])
}

model FailedAnalysis {
  id          String   @id @default(cuid())
  documentId  String
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userId      String
  error       String   @db.Text
  errorCode   String?
  input       Json     // serialized pipeline input for retry
  retryCount  Int      @default(0)
  maxRetries  Int      @default(3)
  nextRetryAt DateTime?
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([resolvedAt])
  @@index([nextRetryAt])
}

model ShareLinkAccess {
  id          String   @id @default(cuid())
  shareLinkId String
  shareLink   ShareLink @relation(fields: [shareLinkId], references: [id], onDelete: Cascade)
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([shareLinkId])
}

model BatchUpload {
  id          String   @id @default(cuid())
  userId      String
  orgId       String?
  status      String   @default("pending") // pending, processing, completed, failed
  totalFiles  Int
  completed   Int      @default(0)
  failed      Int      @default(0)
  errors      Json?    // [{filename, error}]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, status])
}

// ─── Behavioral Data Flywheel ─────────────────────────────────────────────

model CalibrationProfile {
  id               String   @id @default(cuid())
  orgId            String?
  userId           String?
  profileType      String   // "bias_severity" | "nudge_threshold" | "twin_weight"
  calibrationData  Json     // org-specific learned weights
  sampleSize       Int      @default(0)
  lastCalibratedAt DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([orgId, userId, profileType])
  @@index([orgId])
  @@index([userId])
  @@index([profileType])
}

// ─── Public API Keys ──────────────────────────────────────────────────────

model ApiKey {
  id          String    @id @default(cuid())
  userId      String
  orgId       String?
  name        String
  keyHash     String    @unique
  keyPrefix   String    // First 8 chars of the key for display (e.g., "di_live_a1b2...")
  scopes      String[]  // ["analyze", "documents", "outcomes", "insights"]
  rateLimit   Int       @default(100) // requests per hour
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  usages      ApiKeyUsage[]

  @@index([keyHash])
  @@index([userId])
  @@index([keyPrefix])
}

model ApiKeyUsage {
  id           String   @id @default(cuid())
  keyId        String
  endpoint     String
  method       String
  statusCode   Int
  responseTime Int
  createdAt    DateTime @default(now())

  apiKey       ApiKey   @relation(fields: [keyId], references: [id], onDelete: Cascade)

  @@index([keyId])
  @@index([createdAt])
}

