generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pg_graphql(schema: "graphql"), pg_stat_statements(schema: "extensions"), pgcrypto(schema: "extensions"), uuid_ossp(map: "uuid-ossp", schema: "extensions"), vector(schema: "extensions")]
}

model Document {
  id               String              @id @default(cuid())
  userId           String
  filename         String
  fileType         String
  fileSize         Int
  content          String              @db.Text
  contentEncrypted String?             @db.Text
  contentIv        String?
  contentTag       String?
  uploadedAt       DateTime            @default(now())
  status           String              @default("pending")
  updatedAt        DateTime            @updatedAt
  contentHash      String?             @unique
  orgId            String?
  documentType String?            // ic_memo | cim | pitch_deck | term_sheet | due_diligence | lp_report | other
  dealId      String?
  deal        Deal?               @relation(fields: [dealId], references: [id], onDelete: SetNull)
  analyses    Analysis[]
  embeddings  DecisionEmbedding[]
  failedAnalyses FailedAnalysis[]
  decisionFrame DecisionFrame?

  @@index([userId])
  @@index([orgId])
  @@index([updatedAt])
  @@index([contentHash])
  @@index([dealId])
}

model Analysis {
  id                  String         @id @default(cuid())
  documentId          String
  overallScore        Float
  noiseScore          Float
  summary             String        @db.Text
  createdAt           DateTime       @default(now())
  compliance          Json?
  factCheck           Json?
  noiseStats          Json?
  preMortem           Json?
  sentiment           Json?
  speakers            String[]
  structuredContent   String?        @db.Text
  updatedAt           DateTime       @updatedAt
  logicalAnalysis     Json?
  swotAnalysis        Json?
  cognitiveAnalysis   Json?
  simulation          Json?
  institutionalMemory Json?
  modelVersion        String?
  noiseBenchmarks     Json?
  intelligenceContext Json?
  metaVerdict         String?        @db.Text
  biasWebImageUrl     String?
  preMortemImageUrl   String?
  preMortemRating     Int?

  // Version tracking and prompt reference
  version         Int             @default(1)
  promptVersionId String?
  promptVersion   PromptVersion?  @relation(fields: [promptVersionId], references: [id], onDelete: SetNull)

  // Outcome tracking — mandatory flywheel
  outcomeStatus   String          @default("pending_outcome") // pending_outcome | outcome_logged | outcome_overdue
  outcomeDueAt    DateTime?       // When outcome should be reported

  document            Document       @relation(fields: [documentId], references: [id], onDelete: Cascade)
  biases              BiasInstance[]
  versions     AnalysisVersion[]
  shareLinks   ShareLink[]
  outcome      DecisionOutcome?
  prior        DecisionPrior?

  toxicCombinations ToxicCombination[]
  draftOutcomes     DraftOutcome[]

  @@index([documentId])
}

model BiasInstance {
  id          String   @id @default(cuid())
  analysisId  String
  biasType    String
  severity    String
  excerpt     String   @db.Text
  explanation String   @db.Text
  suggestion  String   @db.Text
  confidence  Float?   @default(0.0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userRating  Int?
  analysis    Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([analysisId])
}

model DecisionEmbedding {
  id         String                 @id @default(cuid())
  documentId String
  content    String
  embedding  Unsupported("vector")?
  metadata   Json?
  document   Document               @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  orgId      String?
  action     String
  resource   String
  resourceId String?
  details    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([orgId])
  @@index([action])
}

model UserSettings {
  id                  String   @id @default(cuid())
  userId              String   @unique
  updatedAt           DateTime @updatedAt
  analysisAlerts      Boolean  @default(true)
  createdAt           DateTime @default(now())
  darkMode            Boolean  @default(true)
  emailNotifications  Boolean  @default(true)
  weeklyDigest        Boolean  @default(false)
  onboardingCompleted Boolean  @default(false)
  onboardingStep      Int      @default(0)

  @@index([userId])
}

model CacheEntry {
  key       String   @id
  value     String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

model NewsArticle {
  id              String   @id @default(cuid())
  title           String
  source          String
  publishedAt     DateTime
  relevanceScore  Float    @default(0)
  biasTypes       String[]
  createdAt       DateTime @default(now())
  description     String
  expiresAt       DateTime
  extractedTopics String[]
  feedCategory    String
  industrySector  String?
  link            String   @unique

  @@index([feedCategory])
  @@index([expiresAt])
  @@index([publishedAt])
  @@index([relevanceScore])
}

model ResearchCache {
  id            String   @id @default(cuid())
  doi           String?  @unique
  abstract      String
  authors       String[]
  biasTypes     String[]
  createdAt     DateTime @default(now())
  expiresAt     DateTime
  citationCount Int      @default(0)
  paperTitle    String
  source        String
  sourceUrl     String?
  year          Int?

  @@index([biasTypes])
  @@index([expiresAt])
}

model CaseStudy {
  id        String                 @id @default(cuid())
  title     String
  industry  String?
  outcome   String
  createdAt DateTime               @default(now())
  biasTypes String[]
  company   String
  embedding Unsupported("vector")?
  lessons   String
  summary   String
  year      Int?

  @@index([biasTypes])
  @@index([industry])
}

model IntelligenceSync {
  id              String   @id @default(cuid())
  status          String
  articlesAdded   Int      @default(0)
  articlesExpired Int      @default(0)
  createdAt       DateTime @default(now())
  durationMs      Int      @default(0)
  errors          Json?
  feedsProcessed  Int      @default(0)
  syncType        String

  @@index([syncType])
  @@index([createdAt])
}

model Organization {
  id        String       @id @default(cuid())
  name      String
  slug      String       @unique
  avatarUrl String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  isAnonymized Boolean      @default(false) // Consent to anonymous aggregation
  invites      TeamInvite[]
  members      TeamMember[]

  @@index([slug])
}

model TeamMember {
  id           String       @id @default(cuid())
  orgId        String
  userId       String
  email        String
  displayName  String?
  role         String       @default("member")
  joinedAt     DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@unique([orgId, email])
  @@index([orgId])
  @@index([userId])
}

model TeamInvite {
  id              String       @id @default(cuid())
  orgId           String
  email           String
  role            String       @default("member")
  invitedByUserId String
  token           String       @unique @default(cuid())
  status          String       @default("pending")
  createdAt       DateTime     @default(now())
  expiresAt       DateTime
  organization    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, email])
  @@index([orgId])
  @@index([email])
  @@index([token])
}

model SlackInstallation {
  id                String    @id @default(cuid())
  teamId            String    @unique
  teamName          String
  orgId             String?
  installedByUserId String
  botTokenEncrypted String
  botTokenIv        String
  botTokenTag       String
  botUserId         String?
  scopes            String[]
  status            String    @default("active")
  revokedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([teamId])
  @@index([orgId])
  @@index([installedByUserId])
  @@index([status])
}

model Meeting {
  id                    String             @id @default(cuid())
  userId                String
  orgId                 String?
  title                 String
  meetingType           String             @default("general")
  source                String             @default("upload")
  sourceRef             String?
  fileName              String?
  fileType              String?
  fileSize              Int?
  storagePath           String?
  durationSeconds       Int?
  participants          String[]
  status                String             @default("uploading")
  errorMessage          String?
  transcriptionProgress Float              @default(0)
  summary               String?
  actionItems           Json?
  keyDecisions          Json?
  speakerBiases         Json?
  similarMeetings       Json?
  humanDecisionId       String?            @unique
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  humanDecision         HumanDecision?     @relation(fields: [humanDecisionId], references: [id], onDelete: SetNull)
  transcript            MeetingTranscript?

  @@index([userId])
  @@index([orgId])
  @@index([status])
  @@index([createdAt])
}

model MeetingTranscript {
  id         String   @id @default(cuid())
  meetingId  String   @unique
  speakers   Json     @default("[]")
  segments   Json     @default("[]")
  fullText   String
  language   String   @default("en")
  confidence Float    @default(0)
  createdAt  DateTime @default(now())
  meeting    Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
}

model HumanDecision {
  id               String          @id @default(cuid())
  userId           String
  orgId            String?
  source           String
  sourceRef        String?
  channel          String?
  decisionType     String?
  participants     String[]
  content          String
  contentHash      String?         @unique
  linkedAnalysisId String?
  status           String          @default("pending")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  cognitiveAudit   CognitiveAudit?
  meeting          Meeting?
  nudges           Nudge[]
  decisionFrames   DecisionFrame[]  @relation("DecisionFrameLinkedDecision")
  journalEntries   JournalEntry[]   @relation("JournalLinkedDecision")

  @@index([userId])
  @@index([orgId])
  @@index([source])
  @@index([channel])
  @@index([createdAt])
  @@index([contentHash])
}

model CognitiveAudit {
  id                   String        @id @default(cuid())
  humanDecisionId      String        @unique
  decisionQualityScore Float
  noiseScore           Float
  sentimentScore       Float?
  biasFindings         Json?
  noiseStats           Json?
  complianceResult     Json?
  preMortem            Json?
  logicalAnalysis      Json?
  swotAnalysis         Json?
  sentimentDetail      Json?
  teamConsensusFlag    Boolean       @default(false)
  dissenterCount       Int           @default(0)
  biasWebImageUrl      String?
  preMortemImageUrl    String?
  summary              String
  modelVersion         String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  humanDecision        HumanDecision @relation(fields: [humanDecisionId], references: [id], onDelete: Cascade)

  @@index([humanDecisionId])
  @@index([createdAt])
}

model Nudge {
  id              String         @id @default(cuid())
  targetUserId    String?
  orgId           String?
  humanDecisionId String?
  nudgeType       String
  message         String
  createdAt       DateTime       @default(now())
  acknowledgedAt  DateTime?
  channel         String         @default("dashboard")
  deliveredAt     DateTime?
  outcomeNotes    String?
  severity        String         @default("info")
  triggerReason   String
  wasHelpful      Boolean?
  experimentId    String?
  experiment      NudgeExperiment? @relation(fields: [experimentId], references: [id], onDelete: SetNull)
  variantId       String?        // Which variant was served
  decisionFrameId String?
  decisionFrame   DecisionFrame? @relation(fields: [decisionFrameId], references: [id], onDelete: SetNull)
  parentNudgeId   String?
  parentNudge     Nudge?         @relation("NudgeEscalation", fields: [parentNudgeId], references: [id], onDelete: SetNull)
  childNudges     Nudge[]        @relation("NudgeEscalation")
  phase           String         @default("post_decision") // "pre_decision" | "post_decision"
  failureCount  Int       @default(0)
  lastAttemptAt DateTime?
  nextRetryAt   DateTime?
  humanDecision   HumanDecision? @relation(fields: [humanDecisionId], references: [id])

  @@index([humanDecisionId])
  @@index([orgId])
  @@index([nudgeType])
  @@index([targetUserId])
  @@index([createdAt])
  @@index([experimentId])
  @@index([decisionFrameId])
  @@index([parentNudgeId])
  @@index([channel, deliveredAt, nextRetryAt])
}

model NudgeExperiment {
  id            String   @id @default(cuid())
  name          String
  nudgeType     String   // which nudge type is being tested
  status        String   @default("active") // active, paused, completed
  variants      Json     // Array<{ id: string, label: string, template: string, severity: string }>
  trafficSplit  Json     // { [variantId]: number } — percentage allocation (must sum to 100)
  startedAt     DateTime @default(now())
  endedAt       DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  nudges        Nudge[]

  @@index([nudgeType])
  @@index([status])
}

model TeamCognitiveProfile {
  id                 String   @id @default(cuid())
  orgId              String
  periodStart        DateTime
  periodEnd          DateTime
  createdAt          DateTime @default(now())
  avgDecisionQuality Float
  avgNoiseScore      Float
  consistencyTrend   Json?
  nudgeEffectiveness Json?
  totalDecisions     Int      @default(0)
  updatedAt          DateTime @updatedAt
  topBiases          Json

  @@unique([orgId, periodStart, periodEnd])
  @@index([orgId])
  @@index([periodStart])
}

model DecisionOutcome {
  id                 String   @id @default(cuid())
  analysisId         String   @unique
  userId             String
  orgId              String?
  outcome            String
  timeframe          String?
  impactScore        Int?
  notes              String?
  lessonsLearned     String?
  confirmedBiases    String[]
  falsPositiveBiases String[]
  mostAccurateTwin   String?
  reportedAt         DateTime @default(now())
  updatedAt          DateTime @updatedAt

  analysis Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  decisionRooms DecisionRoom[]

  @@index([analysisId])
  @@index([userId])
  @@index([orgId])
  @@index([outcome])
  @@index([reportedAt])
  @@index([userId, reportedAt])
  @@index([orgId, reportedAt])
}

model BoardroomPersona {
  id            String   @id @default(cuid())
  orgId         String?
  userId        String
  name          String
  role          String
  focus         String
  values        String
  bias          String
  riskTolerance String   @default("moderate")
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([orgId])
  @@index([userId])
  @@index([isActive])
}

model ShareLink {
  id           String    @id @default(cuid())
  token        String    @unique @default(cuid())
  analysisId   String
  userId       String
  orgId        String?
  expiresAt    DateTime?
  revokedAt    DateTime?
  password     String?
  viewCount    Int       @default(0)
  lastViewedAt DateTime?
  isCaseStudy  Boolean   @default(false)
  createdAt    DateTime  @default(now())

  analysis   Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  accesses   ShareLinkAccess[]

  @@index([token])
  @@index([analysisId])
  @@index([userId])
  @@index([expiresAt])
}

model NotificationLog {
  id        String   @id @default(cuid())
  userId    String
  channel   String
  type      String
  subject   String?
  status    String   @default("sent")
  metadata  Json?
  error     String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([channel])
  @@index([type])
  @@index([createdAt])
}

model RateLimit {
  id         String   @id @default(cuid())
  identifier String
  route      String
  count      Int      @default(0)
  resetAt    DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, route])
  @@index([identifier])
  @@index([resetAt])
}

// ─── Versioning & Observability Models ─────────────────────────────────────

model AnalysisVersion {
  id            String   @id @default(cuid())
  analysisId    String
  analysis      Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  version       Int      @default(1)
  overallScore  Float
  noiseScore    Float
  summary       String   @db.Text
  biases        Json     // snapshot of BiasInstance[] at this version
  fullSnapshot  Json     // complete analysis output snapshot
  createdAt     DateTime @default(now())

  @@unique([analysisId, version])
  @@index([analysisId])
}

model PromptVersion {
  id          String   @id @default(cuid())
  name        String   // e.g. "BIAS_DETECTIVE_PROMPT", "SIMULATION_SUPER_PROMPT"
  version     Int
  hash        String   // SHA-256 of prompt content for change detection
  content     String   @db.Text
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  analyses    Analysis[]

  @@unique([name, version])
  @@index([name, isActive])
}

model FailedAnalysis {
  id          String   @id @default(cuid())
  documentId  String
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userId      String
  error       String   @db.Text
  errorCode   String?
  input       Json     // serialized pipeline input for retry
  retryCount  Int      @default(0)
  maxRetries  Int      @default(3)
  nextRetryAt DateTime?
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([resolvedAt])
  @@index([nextRetryAt])
}

model ShareLinkAccess {
  id          String   @id @default(cuid())
  shareLinkId String
  shareLink   ShareLink @relation(fields: [shareLinkId], references: [id], onDelete: Cascade)
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([shareLinkId])
}

model BatchUpload {
  id          String   @id @default(cuid())
  userId      String
  orgId       String?
  status      String   @default("pending") // pending, processing, completed, failed
  totalFiles  Int
  completed   Int      @default(0)
  failed      Int      @default(0)
  errors      Json?    // [{filename, error}]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, status])
}

// ─── Behavioral Data Flywheel ─────────────────────────────────────────────

model CalibrationProfile {
  id               String   @id @default(cuid())
  orgId            String?
  userId           String?
  profileType      String   // "bias_severity" | "nudge_threshold" | "twin_weight"
  calibrationData  Json     // org-specific learned weights
  sampleSize       Int      @default(0)
  lastCalibratedAt DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([orgId, userId, profileType])
  @@index([orgId])
  @@index([userId])
  @@index([profileType])
}

// ─── Causal AI Layer (Moat 1) ─────────────────────────────────────────────

model CausalEdge {
  id         String   @id @default(cuid())
  orgId      String?
  fromVar    String   // e.g., "confirmation_bias"
  toVar      String   // e.g., "noise_score"
  strength   Float    // learned from outcome data (-1 to 1)
  confidence Float    // sample size confidence (0-1)
  sampleSize Int
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  @@unique([orgId, fromVar, toVar])
  @@index([orgId])
}

model OrgCausalModel {
  id            String   @id @default(cuid())
  orgId         String   @unique
  weights       Json     // CausalWeight[] — per-bias danger multipliers
  insights      Json     // CausalInsight[] — human-readable findings
  totalOutcomes Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([orgId])
}

// ─── Structured RLHF (Moat 3) ────────────────────────────────────────────

model DecisionPrior {
  id                 String   @id @default(cuid())
  analysisId         String   @unique
  userId             String
  defaultAction      String   @db.Text // "What would you do with no info?"
  confidence         Float              // 0-100
  evidenceToChange   String?  @db.Text // "What would change your mind?"
  postAnalysisAction String?  @db.Text // What they actually decided
  beliefDelta        Float?             // Calculated shift
  createdAt          DateTime @default(now())

  analysis Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Outcomes-First Workflow (Moat 4) ─────────────────────────────────────

model DecisionFrame {
  id                String   @id @default(cuid())
  userId            String
  orgId             String?
  decisionStatement String   @db.Text
  defaultAction     String   @db.Text
  successCriteria   String[]
  failureCriteria   String[]
  stakeholders      String[]
  monetaryValue     Decimal?  // Estimated decision value
  currency          String?   @default("GBP") // ISO currency code
  documentId        String?  @unique
  threadTs          String?  // Slack thread timestamp for pre-decision monitoring
  channelId         String?  // Slack channel ID for thread tracking
  linkedDecisionId  String?
  linkedDecision    HumanDecision? @relation("DecisionFrameLinkedDecision", fields: [linkedDecisionId], references: [id], onDelete: SetNull)
  nudgeCount        Int      @default(0) // How many nudges delivered in this thread
  escalationLevel   String   @default("none") // "none" | "info" | "warning" | "critical"
  accumulatedBiases Json?    // Array of {bias, signal, detectedAt} across all thread messages
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  document Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)
  nudges   Nudge[]

  @@index([userId])
  @@index([orgId])
  @@index([channelId, threadTs])
  @@index([linkedDecisionId])
}

// ─── Deep Vertical Integration — Compliance (Moat 5) ─────────────────────

// ─── Decision Rooms (Real-Time Collaboration) ────────────────────────────

model DecisionRoom {
  id            String          @id @default(cuid())
  documentId    String?
  analysisId    String?
  title         String
  createdBy     String          // userId
  orgId         String?
  status        String          @default("open") // open, closed, archived
  decisionType  String?         // "investment_committee" | "board_review" | "deal_committee" | "risk_committee" | "general"
  consensusScore Float?         // 0-100, computed from blind prior convergence on close
  dissenterWeight Json?         // { userId: predictionAccuracy } — learned from outcomes
  outcomeId     String?
  outcome       DecisionOutcome? @relation(fields: [outcomeId], references: [id], onDelete: SetNull)
  biasBriefing  Json?           // Auto-generated pre-meeting bias context from linked analysis
  closedAt      DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  participants  RoomParticipant[]
  blindPriors   BlindPrior[]

  @@index([createdBy])
  @@index([orgId])
  @@index([status])
  @@index([decisionType])
  @@index([outcomeId])
}

model RoomParticipant {
  id            String       @id @default(cuid())
  roomId        String
  userId        String
  role          String       @default("member") // creator, member, observer
  joinedAt      DateTime     @default(now())
  room          DecisionRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([userId])
}

model BlindPrior {
  id            String       @id @default(cuid())
  roomId        String
  userId        String
  defaultAction String       @db.Text
  confidence    Float        // 0-100
  reasoning     String?      @db.Text
  isRevealed    Boolean      @default(false) // blind until all submit
  submittedAt   DateTime     @default(now())
  room          DecisionRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([roomId])
}

// ─── Automated Decision Journal ──────────────────────────────────────────

model JournalEntry {
  id            String   @id @default(cuid())
  userId        String
  orgId         String?
  source        String   // email_forward, calendar_webhook, manual, slack_digest
  sourceRef     String?  // message-id for email, event-id for calendar
  title         String
  content       String   @db.Text
  extractedDecisions String[] // AI-extracted decision statements
  decisionType  String?
  participants  String[]
  scheduledAt   DateTime? // for calendar events
  processedAt   DateTime?
  status        String   @default("pending") // pending, processed, dismissed
  linkedDecisionId String?
  linkedDecision   HumanDecision? @relation("JournalLinkedDecision", fields: [linkedDecisionId], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([orgId])
  @@index([source])
  @@index([status])
  @@index([createdAt])
  @@index([linkedDecisionId])
}

// ─── Public API Keys ──────────────────────────────────────────────────────

model ApiKey {
  id          String    @id @default(cuid())
  userId      String
  orgId       String?
  name        String
  keyHash     String    @unique
  keyPrefix   String    // First 8 chars of the key for display (e.g., "di_live_a1b2...")
  scopes      String[]  // ["analyze", "documents", "outcomes", "insights"]
  rateLimit   Int       @default(100) // requests per hour
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  usages      ApiKeyUsage[]

  @@index([keyHash])
  @@index([userId])
  @@index([keyPrefix])
}

model ApiKeyUsage {
  id           String   @id @default(cuid())
  keyId        String
  endpoint     String
  method       String
  statusCode   Int
  responseTime Int
  createdAt    DateTime @default(now())

  apiKey       ApiKey   @relation(fields: [keyId], references: [id], onDelete: Cascade)

  @@index([keyId])
  @@index([createdAt])
}

// ─── Toxic Combination Detection (Wiz-Inspired Moat) ─────────────────────

model ToxicCombination {
  id                String    @id @default(cuid())
  orgId             String?
  analysisId        String?
  biasTypes         String[]  // e.g., ["confirmation_bias", "anchoring"]
  contextFactors    Json      // { monetaryStakes: "high", dissentAbsent: true, timePressure: true }
  toxicScore        Float     // compound risk score (0-100)
  historicalFailRate Float?   // how often this combo led to failures
  sampleSize        Int       @default(0)
  patternLabel      String?   // e.g., "The Echo Chamber"
  status            String    @default("active") // active, acknowledged, mitigated
  acknowledgedAt    DateTime?
  acknowledgedBy    String?
  mitigationNotes   String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  analysis Analysis? @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([analysisId])
  @@index([toxicScore])
  @@index([status])
}

model ToxicPattern {
  id             String   @id @default(cuid())
  orgId          String?  // null = global pattern
  biasTypes      String[] // the bias combination
  contextPattern Json     // required context factors for match
  failureRate    Float    // 0-1, from historical outcomes
  avgImpactDelta Float    // avg impact score difference vs baseline
  sampleSize     Int
  label          String?  // human-readable name, e.g., "The Echo Chamber"
  description    String?  // why this combo is dangerous
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([orgId])
  @@index([failureRate])
}

// ─── Decision Knowledge Graph (Moat: Wiz-Inspired Decision Graph) ────────

model DecisionEdge {
  id            String   @id @default(cuid())
  orgId         String?

  // Source node (polymorphic: can be Analysis or HumanDecision)
  sourceType    String   // "analysis" | "human_decision"
  sourceId      String

  // Target node (polymorphic)
  targetType    String   // "analysis" | "human_decision"
  targetId      String

  // Edge metadata
  edgeType      String   // "influenced_by" | "escalated_from" | "reversed" | "depends_on" | "similar_to" | "shared_bias" | "same_participants"
  strength      Float    // 0-1
  confidence    Float    // 0-1
  description   String?
  metadata      Json?

  // Provenance
  createdBy     String   @default("system") // "system" | userId
  isManual      Boolean  @default(false)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([sourceType, sourceId, targetType, targetId, edgeType])
  @@index([orgId])
  @@index([sourceType, sourceId])
  @@index([targetType, targetId])
  @@index([edgeType])
  @@index([strength])
}

// ─── Autonomous Outcome Detection ────────────────────────────────────────

model DraftOutcome {
  id              String   @id @default(cuid())
  analysisId      String
  outcome         String   // success | partial_success | failure | inconclusive
  confidence      Float
  evidence        String[] // quotes or article titles
  matchedCriteria String[]
  source          String   // document | slack | web_intelligence
  sourceRef       String   // document ID, slack ts, or URL
  status          String   @default("pending_review") // pending_review | confirmed | dismissed
  createdAt       DateTime @default(now())
  reviewedAt      DateTime?

  analysis Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([analysisId])
  @@index([status])
}

// ─── PE/VC Deal Management ───────────────────────────────────────────────

model Deal {
  id            String        @id @default(cuid())
  orgId         String
  name          String                          // "Acme Corp Series B"
  dealType      String                          // buyout | growth_equity | venture | secondary | add_on | recapitalization
  stage         String        @default("screening") // screening | due_diligence | ic_review | closing | portfolio | exited
  sector        String?                         // technology | healthcare | industrials | consumer | financial_services | energy
  ticketSize    Decimal?                        // Investment amount
  currency      String        @default("USD")
  fundName      String?                         // "Fund IV"
  vintage       Int?                            // Fund vintage year
  targetCompany String?                         // Company being evaluated
  status        String        @default("active") // active | passed | invested | written_off | exited
  exitDate      DateTime?
  documents     Document[]

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([orgId, stage])
  @@index([orgId, status])
  @@index([orgId, dealType])
}

// ─── Chat Persistence ─────────────────────────────────────────────────────

model ChatSession {
  id              String        @id @default(cuid())
  userId          String
  title           String        @default("New Chat")
  pinnedDocId     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt


  @@index([userId, updatedAt])
}

model ApiUsage {
  id        String   @id @default(cuid())
  userId    String?
  orgId     String?
  provider  String   // "gemini", "slack", "resend", etc.
  operation String   // "generate", "embed", "send_email", etc.
  tokens    Int?     // for LLM calls
  cost      Float?   // estimated cost in USD
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([orgId, createdAt])
  @@index([provider, createdAt])
  @@index([userId, createdAt])
}

// ─── Decision Copilot ────────────────────────────────────────────────────

model CopilotSession {
  id              String        @id @default(cuid())
  userId          String
  orgId           String?
  title           String        @default("New Decision")
  decisionPrompt  String        @db.Text
  status          String        @default("active") // active, resolved, archived
  resolvedAt      DateTime?
  decisionSummary String?       @db.Text
  dqiScore        Float?
  chosenOption    String?       // Which option the user ultimately chose
  metadata        Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  turns           CopilotTurn[]
  outcome         CopilotOutcome?

  @@index([userId, updatedAt])
  @@index([orgId])
  @@index([status])
}

model CopilotOutcome {
  id              String         @id @default(cuid())
  sessionId       String         @unique
  userId          String
  orgId           String?
  outcome         String         // success | partial_success | failure | inconclusive
  impactScore     Int?           // 1-10
  lessonsLearned  String?        @db.Text
  whatWorked      String?        @db.Text
  whatFailed      String?        @db.Text
  wouldChooseSame Boolean?       // Would you make the same decision again?
  helpfulAgents   String[]       // Which copilot agents were most helpful?
  reportedAt      DateTime       @default(now())
  session         CopilotSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([orgId])
  @@index([outcome])
  @@index([reportedAt])
}

model CopilotTurn {
  id        String         @id @default(cuid())
  sessionId String
  role      String         // "user" | "agent"
  agentType String?        // null for user; "idea_builder" | "devils_advocate" | "scenario_explorer" | "synthesizer"
  content   String         @db.Text
  sources   Json?
  toolCalls Json?
  createdAt DateTime       @default(now())
  session   CopilotSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

// ─── Product Analytics ──────────────────────────────────────────────────

model AnalyticsEvent {
  id         String   @id @default(cuid())
  name       String
  properties Json     @default("{}")
  userId     String?
  sessionId  String?
  createdAt  DateTime @default(now())

  @@index([name])
  @@index([userId])
  @@index([createdAt])
}

// ─── Stripe Billing ──────────────────────────────────────────────────────

model Subscription {
  id                   String    @id @default(cuid())
  userId               String
  orgId                String?
  stripeCustomerId     String    @unique
  stripeSubscriptionId String    @unique
  plan                 String    @default("free") // "free", "pro", "team", "enterprise"
  status               String    @default("active") // "active", "trialing", "past_due", "canceled"
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([userId])
  @@index([orgId])
  @@index([status])
}

// ─── Integration Ecosystem ─────────────────────────────────────────────────

model WebhookSubscription {
  id          String   @id @default(cuid())
  orgId       String
  userId      String
  url         String   // Target URL
  secret      String   // HMAC signing secret (encrypted)
  events      String[] // e.g., ["analysis.completed", "outcome.reported"]
  active      Boolean  @default(true)
  failCount   Int      @default(0)
  lastError   String?
  lastSuccess DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  deliveries  WebhookDelivery[]

  @@index([orgId])
  @@index([active])
}

model WebhookDelivery {
  id              String   @id @default(cuid())
  subscriptionId  String
  event           String
  payload         Json
  statusCode      Int?
  responseBody    String?  @db.Text
  durationMs      Int?
  attempt         Int      @default(1)
  success         Boolean  @default(false)
  createdAt       DateTime @default(now())

  subscription    WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([createdAt])
}

// ─── Multi-Touch Decision Attribution ────────────────────────────────────

model DecisionAttribution {
  id                String   @id @default(cuid())
  outcomeAnalysisId String   // The analysis whose outcome triggered attribution
  sourceAnalysisId  String   // A contributing analysis in the path
  contributionPct   Float    // 0-100 — this source's share of influence
  pathLength        Int      // Hops from source to outcome
  pathEdgeTypes     String[] // Edge types traversed along the path
  edgeStrengthAvg   Float    // Average edge strength along path
  orgId             String?
  computedAt        DateTime @default(now())

  @@unique([outcomeAnalysisId, sourceAnalysisId])
  @@index([outcomeAnalysisId])
  @@index([sourceAnalysisId])
  @@index([orgId])
}

// ─── Calibration Journey (Outcome Gate Gamification) ─────────────────────

model CalibrationMilestone {
  id              String   @id @default(cuid())
  userId          String
  orgId           String?
  milestoneType   String   // "outcomes_reported" | "accuracy_improvement" | "calibration_level"
  milestoneValue  Int      // e.g., 5, 10, 25 outcomes reported
  metricBefore    Float?   // accuracy rate before this milestone
  metricAfter     Float?   // accuracy rate after this milestone
  unlockedAt      DateTime @default(now())

  @@index([userId])
  @@index([orgId])
}

