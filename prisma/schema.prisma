  strength    Float // 0-1
  confidence  Float // 0-1
  description String?
  metadata    Json?

  // Provenance
  createdBy String  @default("system") // "system" | userId
  isManual  Boolean @default(false)
  isSample  Boolean @default(false) // Synthetic seed edge — clearable via /api/demo/clear-samples

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

