model DecisionOutcome {
  id                 String   @id @default(cuid())
  analysisId         String   @unique
  userId             String
  orgId              String?
  outcome            String
  timeframe          String?
  impactScore        Int?
  notes              String?
  lessonsLearned     String?
  confirmedBiases    String[]
  falsPositiveBiases String[]
  mostAccurateTwin   String?
  /// Brier score between predicted DQI and actual outcome. Lower is
  /// better calibrated (0 = perfect, 1 = worst). Nullable for rows
  /// created before brier-scoring.ts shipped; populated on every
  /// outcome submission going forward. See src/lib/learning/brier-scoring.ts.
  brierScore         Float?
  /// Categorical calibration label derived from brierScore — 'excellent'
  /// (<= 0.10), 'good' (<= 0.20), 'fair' (<= 0.35), 'poor' (> 0.35).
  /// Stored alongside the raw score so filter / analytics queries don't
  /// have to recompute the bucket every read.
  brierCategory      String?
  reportedAt         DateTime @default(now())
  updatedAt          DateTime @updatedAt

  analysis      Analysis       @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  decisionRooms DecisionRoom[]

  @@index([analysisId])
