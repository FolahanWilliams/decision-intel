// ─── Decision Provenance Record ───────────────────────────────────────────
//
// Renamed from AuditDefensePacket on 2026-04-22. "Provenance" maps directly
// to EU AI Act Article 14 (record-keeping), SEC AI disclosure language, and
// Basel III ICAAP documentation — proactive posture rather than reactive
// "defense" framing.
//
// Per-audit signed, hashed artifact the CSO's General Counsel can hand to
// the audit committee, SEC, or plaintiff's counsel if a strategic decision
// is ever challenged — or more usefully, the record their AI-augmented
// decision-making was always supposed to produce, before any regulator
// asks. Free add-on for the 5 design partners; scheduled to become a
// Strategy+ bundled feature after the first 12-month cohort.
//
// Each record stores ONLY metadata + hashes — never prompt content, never
// the 20×20 toxic-combination weights, never per-org causal edges. The PDF
// generator reads from this row + the linked Analysis to produce the
// deliverable.
//
// Chain-of-custody timestamp (RFC 3161 TSA) is deferred for v1 — we store
// the serverside Date and leave tsaSignature nullable for a later upgrade
// to DigiCert / Sectigo free TSA endpoints.
model DecisionProvenanceRecord {
  id                 String   @id @default(cuid())
  analysisId         String   @unique
  documentId         String
  userId             String
  orgId              String?
  // SHA-256 of the PromptVersion.content in force at audit time. If prompts
  // rotate, new audits get a new hash; the old record's hash is immutable.
  promptFingerprint  String
  // Hash of the decrypted document content at audit time. Proves the record
  // refers to THIS memo, not a later edit.
  inputHash          String
  // Which model tier ran on which node + temperature + top-p per node.
  // Shape: { [nodeName]: { model, temperature, topP } }
  modelLineage       Json
  // Three-judge outputs + metaJudge arbitration.
  // Shape: { biasDetective, noiseJudge, statisticalJury, metaJudge }
  judgeVariance      Json
  // Each detected bias → taxonomyId + academic citation.
  // Shape: [{ biasType, taxonomyId, citation }]
  citations          Json
  // Which regulatory frameworks apply to the detected risks.
  // Shape: [{ framework, article, applicability }]
  regulatoryMapping  Json
  // Pipeline node order + per-node input/output hashes (hashes only — no
  // content). Shape: [{ node, order, inputHash, outputHash }]
  pipelineLineage    Json
  // Optional RFC 3161 timestamp authority signature (deferred — null for v1).
  tsaSignature       String?
  // Optional reviewer counter-signature block (CSO / GC names + signedAt).
  reviewerSignatures Json?
  // Version of the record schema itself — bump when fields change.
  schemaVersion      Int      @default(1)
  generatedAt        DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  analysis           Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([orgId])
  @@index([documentId])
  @@index([generatedAt])
}

// ─── Design Partner Applications ──────────────────────────────────────────
//
// Inbound applications to the 5-seat design-partner cohort. Warm-intro'd
// CSOs / Heads of Corporate Strategy / M&A leads complete a short form
// at /design-partner; the API persists the application, fires a Slack
// + email notification to the founder, and returns a booking link for
// the intro call. Status transitions (applied → reviewing → accepted /
// declined) are managed via the Founder Hub in a follow-up PR.
//
// The form captures just enough for the founder to triage fast: who +
// where they work + what industry + what's the triggering need + which
// tools they currently use (validates the four-tool graveyard story on
// real data) + how they heard about DI (source attribution).
model DesignPartnerApplication {
  id             String    @id @default(cuid())
  name           String
  email          String
  company        String
  role           String
  linkedInUrl    String?
  industry       String    // banking | insurance | pharma | aerospace | energy | mna | other
  teamSize       String    // '1-5' | '6-15' | '16-50' | '51-200' | '200+'
  memoCadence    String?   // e.g. "3-5 strategic memos per quarter"
  currentStack   String?   // free-text list of tools they use today
  whyNow         String    @db.Text
  source         String?   // warm-intro | linkedin | press | direct | other
  // Internal triage
  status         String    @default("applied")
  // 'applied' | 'reviewing' | 'scheduled_call' | 'accepted' | 'declined' | 'withdrawn'
  founderNotes   String?   @db.Text
  reviewedAt     DateTime?
  callScheduledAt DateTime?
  submittedAt    DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // ─── 5-seat cohort slot (2026-04-24) ──────────────────────────────────
  // Which of the 5 cohort slots this partner occupies. Null means the
  // partner is in the inbound triage queue but hasn't been assigned a
  // cohort seat. 1..5 when assigned. Unique per non-null value so two
  // partners can't share slot 1.
  slotOrder Int?

  // ─── Rich profile (2026-04-24) ────────────────────────────────────────
  // Structured per-partner briefing consumed by the Design Partners tab
  // detail view. Shape lives in src/types/partner-profile.ts as
  // PartnerRichProfile; stored as JSON so the shape can evolve without
  // migrations during the pilot-scoping phase. Sections:
  //   whatTheyDo    — company snapshot + scale + heritage
  //   wedges[]      — 5-ish fit wedges, each with DI intersection
  //   offerSpec     — pricing, inclusions, the ask
  //   positioning   — category anchor, opening line, ethos/pathos/logos
  //   introContext  — how the intro happened + framing rule
  //   risks[]       — named risks + mitigation framing
  //   strategic     — why this partner matters for the company
  // Everything is optional so the UI can render progressively as fields
  // are filled in over the pilot-preparation arc.
  richProfile Json?

  contacts PartnerContact[]

  @@index([status])
  @@index([submittedAt])
  @@index([email])
  @@index([slotOrder])
}

// ─── PartnerContact (2026-04-24) ─────────────────────────────────────────
// A specific person at a design partner that the founder is or will be in
// touch with (e.g. the investment partner at Sankore who holds the
// budget, the GC who signs off on the DPA). Each contact carries the
// raw LinkedIn paste the founder dumped plus the Gemini-generated
// meeting-prep plan (populated on demand, persisted for re-reads).
//
// Scoped per-partner so the cohort-detail UI can show "people at Sankore"
// list. Cascades on partner delete.
model PartnerContact {
  id           String @id @default(cuid())
  partnerAppId String

  name        String
  role        String
  linkedInUrl String?
  // Raw profile summary pasted by the founder (About section, bio,
  // recent roles). The meeting-prep route reads this to ground its
  // plan. Required because the prep generator refuses to run with
  // fewer than 40 chars of info.
  linkedInInfo String  @db.Text
  // How the meeting came to be — shared between contacts at the same
  // partner or personalised per contact. Defaults to a stub the UI
  // pre-fills.
  meetingContext String? @db.Text
  // Founder's desired outcome for this specific meeting (different
  // asks for the investment partner vs the GC, for example).
  founderAsk String? @db.Text
  // Generated meeting prep (the full streamed-then-accumulated
  // plan). Null until the founder clicks "Generate meeting prep."
  generatedPrep String?   @db.Text
  generatedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  partnerApp DesignPartnerApplication @relation(fields: [partnerAppId], references: [id], onDelete: Cascade)

  @@index([partnerAppId])
  @@index([createdAt])
}

// ─── Founder Hub: plain to-do list ─────────────────────────────────────────
//
// Deliberately minimal: title, done, optional dueDate. No priority, no
// labels, no drag-drop. The Founder Hub already has heavier roadmap +
// sprint surfaces (UnicornRoadmapTab, ForecastRoadmapTab); this is the
// tab for the day-to-day "what needs to happen this week" list that
// every other roadmap tool is too structured to hold cleanly.
//
// Pinned tasks stick to the top — used for meeting-prep items the
// founder wants to protect from ambient churn (e.g. Thursday CEO call).
model FounderTodo {
  id        String    @id @default(cuid())
  title     String
  done      Boolean   @default(false)
  pinned    Boolean   @default(false)
  dueDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([done, pinned, createdAt])
}

// ─── FOUNDER MEETING LOG ────────────────────────────────────────────
//
// Persistent record of every prep'd meeting from the Outreach Strategy
// tab's MeetingPrepCard. Replaces the pre-existing "notes scattered
// across Google Docs, Slack, Drive" workflow — one row is one meeting,
// from prep through outcome.
//
// The AI-generated prep plan is stored alongside the founder's
// post-meeting notes so a CSO follow-up call can load the plan, the
// notes from last time, and the learnings in one click. The Founder AI
// chat also pulls the most recent records into its system context so
// the mentor knows "where he is right now" without being told each
// session.
//
// No org scope — this is founder-only, gated by FOUNDER_HUB_PASS at
// the route layer.
model FounderMeeting {
  id              String    @id @default(cuid())
  /// Meeting type tag — cso_discovery | vc_pitch | vc_fundraise_first |
  /// advisor_intro | design_partner_review | reference_call |
  /// content_collab | other. String (not enum) so adding new types is
  /// a prompt-only change, no migration.
  meetingType     String
  prospectName    String?
  prospectRole    String?
  prospectCompany String?
  /// Raw LinkedIn info / background the founder pasted into the form.
  /// Nullable 2026-04-24 so past meetings can be logged without having
  /// to generate a prep plan (e.g. the founder wants to capture a
  /// meeting that already happened). Populated when the row was created
  /// via MeetingPrepCard; null when created via the Log-a-past-meeting
  /// path on MeetingsLogTab.
  linkedInInfo    String?   @db.Text
  /// How the meeting came to be (who initiated, what was promised).
  /// Nullable for the same reason as linkedInInfo — manual-log rows
  /// don't require it.
  meetingContext  String?   @db.Text
  /// Founder's desired outcome in his own words. Nullable for manual-log.
  founderAsk      String?   @db.Text
  /// Full streamed-then-saved prep plan from the Gemini meeting-prep
  /// route. Plain prose with UPPERCASE section headers per the prompt.
  /// Nullable 2026-04-24 so manual-log meetings (no prep generation)
  /// can be created. Populated when row came from MeetingPrepCard;
  /// null when created via the Log-a-past-meeting path.
  prepPlan        String?   @db.Text
  /// How this record was created. 'prep' = generated via MeetingPrepCard
  /// (full prep plan streamed). 'log' = manually logged past meeting
  /// (three-tab post-meeting content only). Default 'prep' for backward
  /// compatibility with rows created before this column landed.
  source          String    @default("prep")
  /// When the meeting is / was scheduled for. Null until the founder
  /// logs a date (the form doesn't require it — some meetings are
  /// spontaneous).
  scheduledAt     DateTime?
  /// When the meeting actually happened. Stays null until the founder
  /// marks it completed.
  happenedAt      DateTime?
  /// Post-meeting notes — raw capture while it's fresh. Kept separate
  /// from learnings so the two don't blur.
  notes           String?   @db.Text
  /// What was learned — stable takeaways worth revisiting.
  learnings       String?   @db.Text
  /// Immediate follow-up actions from the meeting.
  nextSteps       String?   @db.Text
  /// Qualitative outcome — progressed | stalled | closed_won |
  /// closed_lost | rescheduled | no_show | other. Feeds founder Brier
  /// calibration on his own prep-to-conversion rate.
  outcome         String?
  /// Workflow state — prep (plan generated, not yet had) | ready
  /// (meeting scheduled, imminent) | completed (met + notes logged) |
  /// cancelled.
  status          String    @default("prep")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status, scheduledAt])
  @@index([happenedAt])
  @@index([createdAt])
}
