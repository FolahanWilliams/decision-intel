#!/bin/sh
# ==============================================================================
# Pre-Commit Hook: Positioning-lint + AI-Powered Architectural Safety Check
# ==============================================================================
# 1. positioning-lint — fast, deterministic, blocks any retired vocabulary
#    from leaking back onto a marketing surface. Near-zero runtime.
# 2. Gemini CLI audit — slower, architectural.
# ==============================================================================

echo ""
echo "🔤 Running positioning-lint (banned-vocabulary scanner)..."
echo ""

npm run lint:positioning
POSITIONING_EXIT_CODE=$?

if [ $POSITIONING_EXIT_CODE -ne 0 ]; then
    echo ""
    echo "╔══════════════════════════════════════════════════════════════╗"
    echo "║  ❌ COMMIT BLOCKED: positioning-lint failed                  ║"
    echo "╠══════════════════════════════════════════════════════════════╣"
    echo "║  Banned vocabulary leaked into a marketing surface.          ║"
    echo "║  Fix in the same commit or add a scoped allowIn rule in     ║"
    echo "║  scripts/lint-positioning.mjs.                              ║"
    echo "╚══════════════════════════════════════════════════════════════╝"
    echo ""
    exit 1
fi

echo ""
echo "🛡  Running silent-catch ratchet..."
echo ""

npm run lint:silent-catches
SILENT_CATCH_EXIT_CODE=$?

if [ $SILENT_CATCH_EXIT_CODE -ne 0 ]; then
    echo ""
    echo "╔══════════════════════════════════════════════════════════════╗"
    echo "║  ❌ COMMIT BLOCKED: silent-catch ratchet failed              ║"
    echo "╠══════════════════════════════════════════════════════════════╣"
    echo "║  New silent .catch(() => null/{}/[]) introduced. Either:    ║"
    echo "║   • Replace an existing silent catch                        ║"
    echo "║   • Upgrade the new one to log.warn(...)                    ║"
    echo "║   • Bump the baseline in lint-silent-catches.mjs with an    ║"
    echo "║     inline comment naming the legitimate exception class    ║"
    echo "║     (CLAUDE.md > Components & Patterns > Fire-and-forget).  ║"
    echo "╚══════════════════════════════════════════════════════════════╝"
    echo ""
    exit 1
fi

echo ""
echo "🔢 Running count-drift ratchet..."
echo ""

npm run lint:counts
COUNT_LINT_EXIT_CODE=$?

if [ $COUNT_LINT_EXIT_CODE -ne 0 ]; then
    echo ""
    echo "╔══════════════════════════════════════════════════════════════╗"
    echo "║  ❌ COMMIT BLOCKED: count-drift ratchet failed               ║"
    echo "╠══════════════════════════════════════════════════════════════╣"
    echo "║  New hardcoded count literal introduced. Either:            ║"
    echo "║   • Interpolate from canonical                              ║"
    echo "║     (\${BIAS_COUNT}, \${FRAMEWORK_COUNT}, etc.)               ║"
    echo "║   • Use getAllRegisteredFrameworks().length                 ║"
    echo "║   • Add // drift-tolerant — <reason> on the same / above    ║"
    echo "║   • Replace an existing count literal                       ║"
    echo "║                                                              ║"
    echo "║  See CLAUDE.md > Drift-class lint discipline.               ║"
    echo "╚══════════════════════════════════════════════════════════════╝"
    echo ""
    exit 1
fi

echo ""
echo "🔍 Running AI Architectural Audit..."
echo ""

# Run the audit script
npm run audit:ai

# Capture exit code
AUDIT_EXIT_CODE=$?

if [ $AUDIT_EXIT_CODE -ne 0 ]; then
    echo ""
    echo "╔══════════════════════════════════════════════════════════════╗"
    echo "║  ❌ COMMIT BLOCKED: AI Audit Failed                          ║"
    echo "╠══════════════════════════════════════════════════════════════╣"
    echo "║  Fix the issues above before committing, or bypass with:    ║"
    echo "║  git commit --no-verify                                     ║"
    echo "╚══════════════════════════════════════════════════════════════╝"
    echo ""
    exit 1
fi

echo ""
echo "✅ AI Audit Passed - Proceeding with commit"
echo ""
