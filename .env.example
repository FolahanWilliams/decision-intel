# =============================================================================
# Decision Intel — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
#   cp .env.example .env.local

# -----------------------------------------------------------------------------
# Database (Supabase Postgres)
# -----------------------------------------------------------------------------
# Pooled connection string (used at runtime by Prisma Client)
DATABASE_URL=postgresql://user:password@host:6543/postgres?pgbouncer=true

# Direct connection string (used by Prisma CLI for migrations)
DIRECT_URL=postgresql://user:password@host:5432/postgres

# -----------------------------------------------------------------------------
# Authentication (Supabase Auth — Google OAuth)
# -----------------------------------------------------------------------------
# From your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# AI / LLM
# -----------------------------------------------------------------------------
# Google AI API key (Gemini models for analysis + embeddings)
GOOGLE_API_KEY=

# Optional: override the default Gemini model
# GEMINI_MODEL_NAME=gemini-2.0-flash

# Optional: Finnhub API key for financial fact-checking
# FINNHUB_API_KEY=

# -----------------------------------------------------------------------------
# Slack Integration
# -----------------------------------------------------------------------------
# Required if Slack webhook is enabled — HMAC-SHA256 signing secret
# SLACK_SIGNING_SECRET=

# Bot token for sending nudge messages via Slack
# SLACK_BOT_TOKEN=xoxb-your-bot-token

# User ID attributed to Slack-ingested decisions (default: 'system-slack')
# SLACK_SYSTEM_USER_ID=

# -----------------------------------------------------------------------------
# Macro Context
# -----------------------------------------------------------------------------
# Federal Reserve Economic Data API key (defaults to DEMO_KEY with rate limits)
# FRED_API_KEY=

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------
# CORS allowed origin (defaults to production Vercel URL)
# ALLOWED_ORIGIN=http://localhost:3000

# API key for the browser extension
# EXTENSION_API_KEY=

# Log level: debug | info | warn | error (default: info)
# LOG_LEVEL=info

# Jules CI integration
# JULES_API_KEY=

# -----------------------------------------------------------------------------
# Stripe Billing
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=              # Stripe secret key (sk_test_... or sk_live_...)
STRIPE_PUBLISHABLE_KEY=         # Stripe publishable key (pk_test_... or pk_live_...)
STRIPE_WEBHOOK_SECRET=          # Stripe webhook endpoint secret (whsec_...)
STRIPE_PRO_PRICE_ID=            # Stripe Price ID for Pro plan
STRIPE_TEAM_PRICE_ID=           # Stripe Price ID for Team plan
