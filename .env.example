# =============================================================================
# Decision Intel — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
#   cp .env.example .env.local

# -----------------------------------------------------------------------------
# Database (Supabase Postgres)
# -----------------------------------------------------------------------------
# Pooled connection string (used at runtime by Prisma Client)
DATABASE_URL=postgresql://user:password@host:6543/postgres?pgbouncer=true

# Direct connection string (used by Prisma CLI for migrations)
DIRECT_URL=postgresql://user:password@host:5432/postgres

# -----------------------------------------------------------------------------
# Authentication (Supabase Auth — Google OAuth)
# -----------------------------------------------------------------------------
# From your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Demo booking URL (Calendly, Cal.com, etc.) — falls back to /demo if unset
NEXT_PUBLIC_DEMO_BOOKING_URL=

# Loom embed URL for the demo video (e.g., https://www.loom.com/embed/xxxxx)
NEXT_PUBLIC_DEMO_VIDEO_URL=

# -----------------------------------------------------------------------------
# AI / LLM
# -----------------------------------------------------------------------------
# Google AI API key (Gemini models for analysis + embeddings)
GOOGLE_API_KEY=

# Optional: override the default Gemini model used for analysis-heavy nodes
# (bias detection, noise judging, scoring, simulation, debate). Defaults to
# gemini-3-flash-preview.
# GEMINI_MODEL_NAME=gemini-3-flash-preview

# Optional: override the cheaper Gemini model used for mechanical nodes
# (PII anonymization, document structuring, topic extraction). Defaults to
# gemini-3.1-flash-lite — ~half the cost of the main model with marginal
# quality loss on these task shapes.
# GEMINI_MODEL_CHEAP=gemini-3.1-flash-lite

# Optional: override the Pro-tier Gemini model used for the final metaJudge
# verdict (highest-leverage single call in the pipeline). Defaults to
# gemini-2.5-pro.
# GEMINI_MODEL_PRO=gemini-2.5-pro

# Optional: enable cross-model noise jury for methodologically stronger noise
# measurement (Kahneman-style "independent judges"). Unset = all 3 judges use
# the main model (measures only stochastic variance, not judgment disagreement).
#
# Cheapest activation (LOWER cost than unset — 1 Flash-lite replaces 1 Flash):
#   NOISE_JURY_MODELS=gemini-3-flash-preview,gemini-3.1-flash-lite
#
# Full cross-model variant (more expensive — adds Pro judge):
#   NOISE_JURY_MODELS=gemini-3-flash-preview,gemini-2.5-pro,gemini-3.1-flash-lite
# NOISE_JURY_MODELS=

# Anthropic API key (Claude — used as fallback when Gemini fails)
# ANTHROPIC_API_KEY=

# Enable multi-model fallback (Gemini → Claude). Set to 'true' to enable.
# AI_FALLBACK_ENABLED=false

# Optional: Finnhub API key for financial fact-checking
# FINNHUB_API_KEY=

# -----------------------------------------------------------------------------
# Slack Integration
# -----------------------------------------------------------------------------
# OAuth App credentials — required for "Connect Slack" integration
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=

# Required if Slack webhook is enabled — HMAC-SHA256 signing secret
# SLACK_SIGNING_SECRET=

# Bot token for sending nudge messages via Slack
# SLACK_BOT_TOKEN=xoxb-your-bot-token

# User ID attributed to Slack-ingested decisions (default: 'system-slack')
# SLACK_SYSTEM_USER_ID=

# AES-256-GCM encryption key for stored Slack bot tokens (64-char hex = 32 bytes)
# SLACK_TOKEN_ENCRYPTION_KEY=

# AES-256-GCM encryption key for document content at rest (64-char hex = 32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# When set, new document uploads are encrypted. Existing plaintext docs remain readable.
# DOCUMENT_ENCRYPTION_KEY=

# Slack channel ID for internal alert notifications
# SLACK_ALERT_CHANNEL=

# -----------------------------------------------------------------------------
# Macro Context
# -----------------------------------------------------------------------------
# Federal Reserve Economic Data API key (defaults to DEMO_KEY with rate limits)
# FRED_API_KEY=

# -----------------------------------------------------------------------------
# Email (Resend)
# -----------------------------------------------------------------------------
# Required for email notifications, weekly digests, and team invites.
# Without this, emails run in silent dry-run mode (no delivery).
# RESEND_API_KEY=re_xxxxxxxxxxxxx

# From address for transactional emails
# EMAIL_FROM=Decision Intel <notifications@decisionintel.ai>

# -----------------------------------------------------------------------------
# Cron Jobs
# -----------------------------------------------------------------------------
# Secret for authenticating scheduled cron requests (Vercel Cron / external)
# Must be 32+ characters. All cron endpoints return 500 without this.
# CRON_SECRET=

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------
# CORS allowed origin (defaults to production Vercel URL)
# ALLOWED_ORIGIN=http://localhost:3000

# API key for the browser extension
# EXTENSION_API_KEY=

# Log level: debug | info | warn | error (default: info)
# LOG_LEVEL=info

# Secret for authenticating journal ingestion webhook
# JOURNAL_INGEST_SECRET=

# Jules CI integration
# JULES_API_KEY=

# -----------------------------------------------------------------------------
# Stripe Billing
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=              # Stripe secret key (sk_test_... or sk_live_...)
STRIPE_PUBLISHABLE_KEY=         # Stripe publishable key (pk_test_... or pk_live_...)
STRIPE_WEBHOOK_SECRET=          # Stripe webhook endpoint secret (whsec_...)
STRIPE_PRO_PRICE_ID=            # Stripe Price ID for Pro plan
STRIPE_TEAM_PRICE_ID=           # Stripe Price ID for Team plan

# Per-Deal Audit pricing tiers (one-time Stripe Checkout)
# STRIPE_DEAL_SMALL_PRICE_ID=   # <$10M deal tier ($499)
# STRIPE_DEAL_MID_PRICE_ID=     # <$50M deal tier ($1,499)
# STRIPE_DEAL_LARGE_PRICE_ID=   # <$200M deal tier ($2,999)
# STRIPE_DEAL_MEGA_PRICE_ID=    # $200M+ deal tier ($4,999)

# -----------------------------------------------------------------------------
# Google Drive Integration
# -----------------------------------------------------------------------------
# OAuth 2.0 credentials for Google Drive connector
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
