# ─── Voice Worker Environment ──────────────────────────────────────────────
# Copy to .env locally, or set in Railway dashboard for production.

# ─── LiveKit Cloud ────────────────────────────────────────────────────────
# Sign in at https://cloud.livekit.io, create a project, grab the WS URL
# + API key + secret from the project's Settings → Keys page.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxx
LIVEKIT_API_SECRET=secret_xxxxxxxxxxxx

# ─── Main app — for fetching /voice-context ───────────────────────────────
# The full origin of the Vercel deployment. Worker calls
# `${MAIN_APP_URL}/api/founder-hub/voice-context?personaId=X` at session
# start to pull FOUNDER_CONTEXT + persona system prompt + voice addendum.
MAIN_APP_URL=https://decision-intel.com

# Shared secret between worker + main app for the /voice-context endpoint.
# Same value must be set in BOTH Railway and Vercel env. Rotate together.
VOICE_WORKER_SECRET=generate-a-random-32-byte-hex-string

# ─── Speech-to-text (Deepgram Nova-3) ──────────────────────────────────────
# https://console.deepgram.com — create an API key with `usage:write`.
DEEPGRAM_API_KEY=

# ─── LLM (Grok 4.3 via Vercel AI Gateway) ──────────────────────────────────
# Reuses the same gateway key the main app uses. AI Gateway exposes an
# OpenAI-compatible endpoint at https://ai-gateway.vercel.sh/v1, so the
# LiveKit OpenAI plugin works against it with `baseURL` overridden.
AI_GATEWAY_API_KEY=
AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1
# Grok 4.3 via AI Gateway. Match the main app's MODEL_FOUNDER_HUB lock.
GROK_MODEL=xai/grok-4.3

# ─── Text-to-speech (Cartesia Sonic-2) ─────────────────────────────────────
# https://cartesia.ai — create an API key. Voice IDs below override the
# stock defaults baked into thinking-partners.ts. Leave blank to use the
# stock voice; set a UUID from the Cartesia dashboard to swap.
CARTESIA_API_KEY=
CARTESIA_VOICE_DEFAULT=
CARTESIA_VOICE_PSYCHOLOGIST=
CARTESIA_VOICE_STRATEGIST=
CARTESIA_VOICE_INVESTOR=
CARTESIA_MODEL=sonic-2
