{
  "name": "decision-intel",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/validate-deploy-env.mjs && npx prisma generate && node scripts/prisma-migrate-safe.mjs && node scripts/seed-business-data.mjs && NODE_OPTIONS='--max-old-space-size=6144' npx tsc --noEmit && NODE_OPTIONS='--max-old-space-size=7168' next build --webpack && node scripts/upload-sourcemaps.mjs",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "postinstall": "prisma generate",
    "jules": "node scripts/jules.js",
    "jules:test": "node scripts/jules.js \"Write comprehensive Jest unit tests for src/lib/agents/nodes.ts covering all edge cases\"",
    "jules:docs": "node scripts/jules.js \"Read all files in src/lib/agents and update AGENTS.md to match the current logic and architecture\"",
    "jules:audit": "node scripts/jules.js \"Audit the entire codebase for security vulnerabilities, hardcoded secrets, and GDPR compliance gaps\"",
    "gemini": "gemini",
    "test": "vitest run",
    "audit:ai": "bash ./scripts/gemini-audit.sh",
    "slop-scan": "bash ./scripts/slop-scan.sh",
    "lint:positioning": "node scripts/lint-positioning.mjs",
    "lint:silent-catches": "node scripts/lint-silent-catches.mjs",
    "lint:counts": "node scripts/lint-counts.mjs",
    "lint:canonical-imports": "node scripts/lint-canonical-imports.mjs",
    "lint:doc-sync": "node scripts/lint-doc-sync.mjs",
    "lint:tenant-isolation": "node scripts/lint-tenant-isolation.mjs",
    "gen:rls": "node scripts/gen-rls-policies.mjs",
    "audit:platform": "node scripts/audit-platform.mjs",
    "audit:platform:write": "node scripts/audit-platform.mjs --write",
    "rotate:encryption-key": "tsx ./scripts/rotate-encryption-key.ts",
    "test:gateway": "tsx ./scripts/test-ai-gateway.ts",
    "sentry:upload-sourcemaps": "npx -y @sentry/cli@latest sourcemaps upload --org=decision-intel-bu --project=decisionintelsentry --release=${VERCEL_GIT_COMMIT_SHA:-$(git rev-parse HEAD)} .next",
    "vercel:logs": "vercel logs --follow",
    "vercel:logs:prod": "vercel logs --prod --follow",
    "vercel:logs:errors": "vercel logs --prod --since=1h --output=raw | grep -iE 'error|exception|prismaclient|failed|warn' | tail -100",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
